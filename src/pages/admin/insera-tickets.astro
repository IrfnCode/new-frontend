        document.getElementById("addForm")?.addEventListener("submit", async (e) => {
            e.preventDefault();

            const orderId = document.getElementById("addOrderId").value.trim();
            const summary = document.getElementById("addSummary").value.trim();

            if (!orderId || !summary) {
                alert("NO INC dan Summary wajib diisi");
                return;
            }

            // Check for duplicate ticket
            try {
                const checkRes = await fetch("/api/insera-tickets", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ action: 'check_duplicate', orderId })
                });
                const checkResult = await checkRes.json();

                if (checkResult.exists) {
                    // Ticket already exists - show alert with details
                    const lastUpdateBy = checkResult.data?.lastUpdateBy || 'Unknown';
                    const status = checkResult.data?.status || 'OPEN';
                    const isClosed = ['CLOSED', 'RESOLVED', 'CANCELLED'].includes(status.toUpperCase());
                    
                    let alertMsg = `⚠️ TIKET SUDAH ADA!\n\n`;
                    alertMsg += `Tiket ${orderId} sudah ${isClosed ? 'di-CLOSE' : 'ada'} oleh @${lastUpdateBy}\n`;
                    alertMsg += `Status: ${status}\n`;
                    if (checkResult.data?.summary) {
                        alertMsg += `Summary: ${checkResult.data.summary}\n`;
                    }
                    
                    if (isClosed) {
                        alertMsg += `\nTiket yang sudah di-CLOSE tidak bisa di-input ulang.`;
                        alert(alertMsg);
                        return;
                    } else {
                        alertMsg += `\nApakah Anda ingin melanjutkan input (akan mengupdate data)?`;
                        if (!confirm(alertMsg)) {
                            return;
                        }
                    }
                }
            } catch (err) {
                console.error("[Add Manual] Duplicate check error:", err);
                // Continue anyway if check fails
            }

            const workOrder = {
                orderId: orderId,
                summary: summary,
                customerType: document.getElementById("addCustomerType").value,
                workzone: document.getElementById("addWorkzone").value || null,
                customerSegment: document.getElementById("addCustomerSegment").value || null,
                reportedDate: document.getElementById("addReportedDate").value || null,
                team: document.getElementById("addTeam").value || null,
                actorName: CURRENT_USER 
            };

            const submitBtn = e.target.querySelector('button[type="submit"]');
            const originalHTML = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">sync</span> Menyimpan...';

            try {
                const response = await fetch(`${API_URL}/api/workorders`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(workOrder),
                });

                const result = await response.json();

                if (result.success || result.status === 'success') {
                    document.getElementById("addModal")?.classList.add("hidden");
                    window.fetchWorkOrders();
                    alert("Work order manual berhasil ditambahkan.");
                } else {
                    alert(result.error || result.message || "Gagal menambahkan data.");
                }
            } catch (error) {
                alert("Gagal menambahkan work order (API belum tersedia)");
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHTML;
            }
        });

    });

    // Return Ticket Modal Functions
    let currentReturnId = null;
    let currentReturnOrderId = null;
    let currentReturnAssignedTo = [];

    window.returnTicket = async function(id, orderId) {
        // Cari data tiket
        const wo = window.allWorkOrders.find(w => w.id === id);
        if (!wo) {
            alert("Data tiket tidak ditemukan");
            return;
        }

        currentReturnId = id;
        currentReturnOrderId = orderId;

        // Parse assigned_to untuk mendapatkan daftar teknisi
        const assigned = wo.assigned_to || wo.assignedTo;
        currentReturnAssignedTo = [];
        if (assigned && assigned !== '[]') {
            try {
                const parsed = typeof assigned === 'string' ? JSON.parse(assigned) : assigned;
                currentReturnAssignedTo = Array.isArray(parsed) ? parsed : [parsed];
            } catch (e) {}
        }

        // Isi modal dengan data tiket
        document.getElementById('returnTicketId').textContent = orderId;
        document.getElementById('returnTicketSummary').textContent = wo.summary || '-';
        document.getElementById('returnTicketWorkzone').textContent = wo.workzone || '-';
        document.getElementById('returnTicketCustType').textContent = wo.customer_type || wo.customerType || 'REGULER';

        // Tampilkan daftar teknisi yang di-assign
        const assignedListEl = document.getElementById('returnAssignedList');
        if (currentReturnAssignedTo.length > 0) {
            const techNames = currentReturnAssignedTo.map(t => {
                const name = typeof t === 'object' ? (t.nama || t.name) : t;
                const tag = typeof t === 'object' ? (t.tag_telegram || t.tagTelegram) : null;
                return tag ? `${name} (${tag})` : name;
            });
            assignedListEl.innerHTML = techNames.map(n => `<span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-primary/10 text-primary">${n}</span>`).join(' ');
        } else {
            assignedListEl.innerHTML = '<span class="text-[11px] italic text-error">Belum di-assign ke teknisi manapun</span>';
        }

        // Reset catatan
        document.getElementById('returnNotes').value = '';

        // Tampilkan modal
        document.getElementById('returnModal').classList.remove('hidden');
    };

    window.closeReturnModal = function() {
        document.getElementById('returnModal').classList.add('hidden');
        currentReturnId = null;
        currentReturnOrderId = null;
        currentReturnAssignedTo = [];
    };

    window.confirmReturnTicket = async function() {
        if (!currentReturnId) return;

        const notes = document.getElementById('returnNotes').value.trim();
        if (!notes) {
            alert("Harap isi catatan untuk pemilik/penanggung jawab tiket");
            return;
        }

        const btn = document.getElementById('confirmReturnBtn');
        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">sync</span> Memproses...';

        try {
            const response = await fetch("/api/insera-tickets", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: 'return_ticket',
                    id: currentReturnId,
                    actorName: CURRENT_USER,
                    notes: notes,
                    assignedTo: currentReturnAssignedTo
                }),
            });
            const result = await response.json();
            if (result.status === 'success') {
                alert("Tiket berhasil di-return. Notifikasi telah dikirim ke grup dan teknisi terkait.");
                closeReturnModal();
                window.fetchWorkOrders();
            } else {
                alert(result.message || "Gagal return tiket.");
            }
        } catch (e) {
            alert("Error: " + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    };
</script>
