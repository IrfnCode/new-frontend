<script is:inline define:vars={{ initialWorkOrders, dbError, PUBLIC_BACKEND_URL }}>
    const API_URL = PUBLIC_BACKEND_URL;

    if (dbError) {
        console.error(`[Dashboard] Database Error: ${dbError}`);
    }

    // --- GLOBAL STATE & UTIL ---
    window.allWorkOrders = initialWorkOrders || [];
    window.filteredWorkOrders = [...window.allWorkOrders];
    window.currentPage = 1;
    window.pageSize = 10;
    window.nakerList = [];
    window.selectedWorkzones = [];
    window.activeTechFilter = null;
    window.activeHdFilter = null;
    const CURRENT_USER = document.querySelector('meta[name="current-user"]')?.content || "Unknown";

    // --- HELPER FUNCTIONS ---
    window.isExpired = function(expiredDate) {
        if (!expiredDate) return false;
        return new Date(expiredDate) < new Date();
    };

    window.isNearExpired = function(expiredDate) {
        if (!expiredDate) return false;
        const exp = new Date(expiredDate);
        const now = new Date();
        const hoursDiff = (exp.getTime() - now.getTime()) / (1000 * 60 * 60);
        return hoursDiff > 0 && hoursDiff <= 2;
    };

    // --- COLUMN PICKER LOGIC (Defined Early to avoid ReferenceErrors) ---
    const COLUMN_DEFS = [
        { key: "order_id",          label: "NO INC",         default: true  },
        { key: "summary",           label: "Summary",         default: true  },
        { key: "reported_by",       label: "Source",          default: true  },
        { key: "device_name",       label: "ODP",             default: true  },
        { key: "rk_information",    label: "ODC",             default: true  },
        { key: "service_no",        label: "No Internet",     default: true  },
        { key: "status",            label: "Status",          default: true  },
        { key: "customer_type",     label: "Cust Type",       default: true  },
        { key: "ticket_type",       label: "Tipe Tiket",      default: true  },
        { key: "customer_segment",  label: "Segment",         default: true  },
        { key: "workzone",          label: "Workzone",        default: true  },
        { key: "ticket_age",        label: "Umur Tiket",      default: true  },
        { key: "ttr",               label: "TTR",             default: true  },
        { key: "reported_date",     label: "Reported Date",   default: true  },
        { key: "team",              label: "Assign To",       default: true  },
        { key: "assigned_by",       label: "Assigned By",     default: true  },
        { key: "actions",           label: "Aksi",            default: true  },
    ];

    const LS_KEY = "morena_ticket_cols";

    function loadColPrefs() {
        try {
            const raw = localStorage.getItem(LS_KEY);
            if (!raw) {
                const prefs = {};
                COLUMN_DEFS.forEach(c => prefs[c.key] = c.default);
                return prefs;
            }
            const saved = JSON.parse(raw);
            if (saved && typeof saved === "object") return saved;
        } catch(e) { console.warn("[Dashboard] localStorage Error:", e); }
        const prefs = {};
        COLUMN_DEFS.forEach(c => prefs[c.key] = c.default);
        return prefs;
    }

    let colPrefs = loadColPrefs();

    function saveColPrefs() {
        localStorage.setItem(LS_KEY, JSON.stringify(colPrefs));
    }

    window.applyColumnVisibility = function() {
        COLUMN_DEFS.forEach(({ key }) => {
            const visible = colPrefs[key] !== false;
            document.querySelectorAll(`[data-col="${key}"]`).forEach(el => {
                el.style.display = visible ? "" : "none";
            });
        });
    };

    function safeParse(json, fallback = []) {
        if (!json) return fallback;
        try {
            const parsed = typeof json === 'string' ? JSON.parse(json) : json;
            return Array.isArray(parsed) ? parsed : (parsed ? [parsed] : []);
        } catch (e) { return fallback; }
    }

    const ALL_WORKZONES = ["BTC","CDN","KAI","NGS","PNI","TUS","BUM","LBJ","MOR","SGT","SYA","TBK","TJT","DGS","SGL","SKN","SLU","TIN","TJU","BDS","AVI","BLP","KIJ","KMS","PYT","TPI","TUB","TER","RAI","DBS"];
    let selectedWorkzones = [];

    // Customer Type multi-select filter
    const ALL_CUST_TYPES = ["HVC PLATINUM", "HVC DIAMOND", "HVC GOLD", "REGULER"];
    let selectedCustTypes = [];

    window.changePageSize = function(size) {
        window.pageSize = parseInt(size);
        window.currentPage = 1;
        window.renderWorkOrders();
    };

    async function loadNaker() {
        try {
            const res = await fetch("/api/manage-technician");
            const result = await res.json();
            if (result.status === "success") {
                nakerList = result.data || [];
            }
        } catch (err) {
            console.warn("Could not load naker data.");
        }
        renderWorkOrders();
    }

    const customerTypeColors = {
        HVC_PLATINUM: "badge-platinum",
        HVC_DIAMOND: "badge-diamond",
        HVC_GOLD: "badge-gold",
        REGULER: "badge-reguler",
    };

    const ticketTypeColors = {
        SQM: "badge-sqm",
        REGULER: "badge-tipe-reguler",
    };

    function formatDate(dateStr) {
        if (!dateStr) return "-";
        const date = new Date(dateStr);
        if (isNaN(date.getTime())) return dateStr;
        return date.toLocaleString("id-ID", {
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit",
        });
    }

    function isExpired(expiredDate) {
        if (!expiredDate) return false;
        return new Date(expiredDate) < new Date();
    }

    function isNearExpired(expiredDate) {
        if (!expiredDate) return false;
        const exp = new Date(expiredDate);
        const now = new Date();
        const hoursDiff = (exp.getTime() - now.getTime()) / (1000 * 60 * 60);
        return hoursDiff > 0 && hoursDiff <= 2; // Within 2 hours
    }

    function getExpiredStatus(expiredDate) {
        if (isExpired(expiredDate)) {
            return { class: "text-error bg-error/10 font-bold border border-error/20", icon: "error" };
        }
        if (isNearExpired(expiredDate)) {
            return { class: "text-amber-500 bg-amber-500/10 font-bold border border-amber-500/20", icon: "schedule" };
        }
        return {
            class: "text-emerald-500 bg-emerald-500/10 font-bold border border-emerald-500/20",
            icon: "check_circle",
        };
    }

    function updateTicketAges() {
        const ageElements = document.querySelectorAll('.ticket-age');
        ageElements.forEach(el => {
            const reported = el.getAttribute('data-reported');
            if (!reported) return;
            const start = new Date(reported).getTime();
            const now = new Date().getTime();
            const diff = now - start;
            if (diff < 0) return;
            
            const hours = Math.floor(diff / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);
            el.textContent = `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
        });
    }

    setInterval(updateTicketAges, 1000);

    // ── TTR (Time To Recover) Helper ─────────────────────────────────────────
    const TTR_HOURS = { 'HVC_DIAMOND': 3, 'HVC_PLATINUM': 6, 'HVC_GOLD': 12, 'REGULER': 24 };
    const USE_BOOKING_TIERS = new Set(['REGULER', 'HVC_GOLD']);

    // TTR hanya berlaku untuk Source = REGULER (bukan SQM/UNSPEC/INFRACARE)
    function isRegulerSource(wo) {
        const src = (wo.reported_by || wo.reportedBy || '').toUpperCase();
        const isSQM       = src.includes('PROACTIVE') && src.includes('TICKET');
        const isUNSPEC    = (src.includes('PROACTIVE') && src.includes('OHI')) || src.startsWith('PROMAN-');
        const isINFRACARE = src.includes('INFRACARE');
        return !isSQM && !isUNSPEC && !isINFRACARE;
    }

    function calcTTR(wo) {
        // TTR hanya untuk source REGULER
        if (!isRegulerSource(wo)) return null;

        const rawTier = (wo.customer_type || wo.customerType || 'REGULER').toUpperCase();
        const tier = Object.keys(TTR_HOURS).find(k => rawTier.includes(k)) || 'REGULER';
        const ttrHours = TTR_HOURS[tier];

        const reportedRaw = wo.reported_date || wo.reportedDate;
        const bookingRaw  = wo.booking_date  || wo.bookingDate;
        if (!reportedRaw) return null;

        let startDate;
        if (USE_BOOKING_TIERS.has(tier) && bookingRaw) {
            const bd = new Date(bookingRaw), rd = new Date(reportedRaw);
            startDate = bd > rd ? bd : rd;
        } else {
            startDate = new Date(reportedRaw);
        }
        if (isNaN(startDate.getTime())) return null;

        const now        = Date.now();
        const expiredAt  = new Date(startDate.getTime() + ttrHours * 3600000);
        const remainMs   = expiredAt.getTime() - now;
        const isExpired  = remainMs <= 0;
        const isNear     = !isExpired && remainMs <= 2 * 3600000;

        const absH = Math.floor(Math.abs(remainMs) / 3600000);
        const absM = Math.floor((Math.abs(remainMs) % 3600000) / 60000);

        const expiredStr = expiredAt.toLocaleString('id-ID', {
            timeZone: 'Asia/Jakarta', day:'2-digit', month:'2-digit',
            year:'numeric', hour:'2-digit', minute:'2-digit', hour12: false
        }).replace(',','');

        const bookingNote = USE_BOOKING_TIERS.has(tier) && bookingRaw && new Date(bookingRaw) > new Date(reportedRaw)
            ? ' <span class="text-[8px] text-on-surface-variant">(dari booking)</span>' : '';

        let statusBadge, remainText;
        if (isExpired) {
            statusBadge = '<span class="px-1.5 py-0.5 rounded text-[8px] font-black bg-error text-white">EXPIRED</span>';
            remainText  = `<span class="text-error font-black">${absH}h ${absM}m LEWAT</span>`;
        } else if (isNear) {
            statusBadge = '<span class="px-1.5 py-0.5 rounded text-[8px] font-black bg-amber-500 text-white">NEAR EXPIRED</span>';
