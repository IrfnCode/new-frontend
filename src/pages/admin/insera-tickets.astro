---
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../components/Sidebar.astro";
import { InseraModel } from "../../lib/models/InseraModel";

const role = Astro.cookies.get("admin_role")?.value;
const username = Astro.cookies.get("admin_user")?.value || "Unknown";

// Guard: hanya ADMIN, KORLAP, HSA, HD/HELPDESK yang boleh akses halaman ini
const allowedRoles = ["ADMIN", "KORLAP", "HSA", "HD KORLAP", "HELPDESK", "HD"];
if (!role || !allowedRoles.includes(role)) {
    return Astro.redirect("/admin/tickets");
}

const isAdmin     = role === "ADMIN";
const isKorlapHsa = role === "KORLAP" || role === "HSA" || role === "HD KORLAP";
const isHelpdesk  = role === "HELPDESK" || role === "HD";

// Fetch initial data directly from MySQL server-side
let initialWorkOrders = [];
let dbError = null;
let dbDiagnostics = { total: 0, status: 'Checking...' };

try {
    const rawOrders = await InseraModel.getAll();
    dbDiagnostics = await InseraModel.getDiagnostics();
    
    console.log("[SSR] rawOrders count:", rawOrders?.length || 0);
    console.log("[SSR] dbDiagnostics:", dbDiagnostics);
    
    initialWorkOrders = (rawOrders || []).map((wo: any) => {
        const item = { ...wo };
        // Handle BigInt conversion for both snake_case and camelCase
        ['id', 'order_id', 'orderId'].forEach(key => {
            if (typeof item[key] === 'bigint') item[key] = item[key].toString();
        });
        return item;
    });
    
    console.log("[SSR] initialWorkOrders count:", initialWorkOrders.length);
} catch (err) {
    dbError = err.message;
    console.error("SSR Database Error:", err.message);
}

const PUBLIC_BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL;
---


<Layout title="MORENA Admin - Data Tiket INSERA">
    <meta name="current-user" content={username} />
    <div class="flex min-h-screen font-body relative overflow-x-hidden">
        <Sidebar activePage="insera-tickets" />

        <main class="ml-[256px] flex-1 flex flex-col min-h-screen bg-surface transition-all duration-500 ease-[cubic-bezier(0.87,0,0.13,1)] overflow-x-hidden">
