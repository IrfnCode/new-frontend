    window.updateStats = function() {
        try {
            // Safety check: ensure allWorkOrders is defined
            const allOrders = window.allWorkOrders || [];
            if (!Array.isArray(allOrders)) {
                console.warn("[updateStats] allWorkOrders is not an array", allOrders);
                return;
            }
            
            const closedStatuses = ["CLOSED", "closed", "RESOLVED", "CANCELLED"];
            const closedCount = allOrders.filter((wo) => closedStatuses.includes(wo.status || wo.TicketStatus)).length;
            const openWorkOrders = allOrders.filter((wo) => !closedStatuses.includes(wo.status || wo.TicketStatus));
            const openCount = openWorkOrders.length;

            // Calculate ticket age based on reported_date
            const now = new Date().getTime();
            const getTicketAgeHours = (wo) => {
                const reported = wo.reported_date || wo.reportedDate;
                if (!reported) return 0;
                const reportedTime = new Date(reported).getTime();
                return (now - reportedTime) / (1000 * 60 * 60);
            };

            // EXPIRED & NEAR EXPIRED: gunakan TTR per-tier (bukan hardcode 24h)
            const expiredCount = openWorkOrders.filter((wo) => {
                const ttr = calcTTR(wo);
                return ttr ? ttr.isExpired : getTicketAgeHours(wo) > 24;
            }).length;
            const nearExpiredCount = openWorkOrders.filter((wo) => {
                const ttr = calcTTR(wo);
                return ttr ? (ttr.isNear && !ttr.isExpired) : (() => {
                    const h = getTicketAgeHours(wo);
                    return h >= 12 && h <= 24;
                })();
            }).length;

            // Assigned count (tickets with assigned_to not null/empty)
            const assignedCount = openWorkOrders.filter((wo) => {
                const assigned = wo.assigned_to || wo.assignedTo;
                return assigned && assigned !== '[]' && assigned !== '';
            }).length;

            const statOpen = document.getElementById("statOpen");
            const statNearExpired = document.getElementById("statNearExpired");
            const statExpired = document.getElementById("statExpired");
            const statAssigned = document.getElementById("statAssigned");
            const statClosed = document.getElementById("statClosed");

            if (statOpen) statOpen.textContent = (openCount || 0).toString();
            if (statNearExpired) statNearExpired.textContent = (nearExpiredCount || 0).toString();
            if (statExpired) statExpired.textContent = (expiredCount || 0).toString();
            if (statAssigned) statAssigned.textContent = (assignedCount || 0).toString();
            if (statClosed) statClosed.textContent = (closedCount || 0).toString();
            console.log(`[Dashboard] Stats updated: ${openCount || 0} open, ${assignedCount || 0} assigned, ${expiredCount || 0} expired (>24h), ${closedCount || 0} closed.`);
        } catch (err) {
            console.error("[Dashboard] updateStats ERROR:", err);
        }
    }

    window.applyFilters = function() {
        try {
            const searchInput = document.getElementById("searchInput")?.value.toLowerCase() || "";
            const dateFilter = document.getElementById("filterDate")?.value || "";
            
            // Get multi-select filter values
            const selectedSegments = Array.from(document.querySelectorAll('input[data-seg]:checked')).map(cb => cb.value);
            const selectedSources = Array.from(document.querySelectorAll('input[data-src]:checked')).map(cb => cb.value);
            const selectedStatuses = Array.from(document.querySelectorAll('input[data-st]:checked')).map(cb => cb.value);

            // Calculate ticket age for filtering
            const now = new Date().getTime();
            const getTicketAgeHours = (wo) => {
                const reported = wo.reported_date || wo.reportedDate;
                if (!reported) return 0;
                return (now - new Date(reported).getTime()) / (1000 * 60 * 60);
            };

            const closedStatuses = ["CLOSED", "closed"];

            window.filteredWorkOrders = window.allWorkOrders.filter((wo) => {
                const order_id = wo.order_id || wo.orderId || "";
                const summary = (wo.summary || wo.title || wo.description || "").toLowerCase();
                const contact_phone = wo.contact_phone || wo.contactPhone || "";
                const service_no = wo.service_no || wo.serviceNo || "";
                const workzone = wo.workzone || wo.workZone || "";
                const status = (wo.status || wo.TicketStatus || "").toUpperCase();
                const segment = (wo.customer_segment || wo.customerSegment || "").toUpperCase().trim();
                const source = (wo.reported_by || wo.reportedBy || "REGULER").toUpperCase().trim();

                const matchesSearch =
                    !searchInput ||
                    (order_id && order_id.toLowerCase().includes(searchInput)) ||
                    (summary && summary.includes(searchInput)) ||
                    (contact_phone && contact_phone.includes(searchInput)) ||
                    (service_no && service_no.includes(searchInput));

                // Segment Filter Logic - Multi-select
                let matchesSegment = true;
                if (selectedSegments.length > 0) {
                    const tselSegments = ["DCS", "PL-TSEL"];
                    const bgesSegments = ["DBS", "DES", "DGS", "DPS", "DSS", "REG", "RBS"];
                    matchesSegment = selectedSegments.some(sel => {
                        if (sel === "TSEL") return tselSegments.some(s => segment.includes(s));
                        if (sel === "BGES") return bgesSegments.some(s => segment.includes(s));
                        return false;
                    });
                }

                // Source Filter Logic - Multi-select
                let matchesSource = true;
                if (selectedSources.length > 0) {
                    matchesSource = selectedSources.some(sel => {
                        if (sel === "PROACTIVE_TICKET") return source.includes("PROACTIVE") && source.includes("TICKET");
                        if (sel === "PROACTIVE_OHI") return (source.includes("PROACTIVE") && source.includes("OHI")) || source.startsWith("PROMAN-");
                        if (sel === "INFRACARE") return source.includes("INFRACARE");
                        if (sel === "REGULER") {
                            const isProactiveTicket = source.includes("PROACTIVE") && source.includes("TICKET");
                            const isProactiveOhi = (source.includes("PROACTIVE") && source.includes("OHI")) || source.startsWith("PROMAN-");
                            const isInfracare = source.includes("INFRACARE");
                            return !isProactiveTicket && !isProactiveOhi && !isInfracare;
                        }
                        return false;
                    });
                }

                const matchesWorkzone = selectedWorkzones.length === 0 || selectedWorkzones.includes(workzone);

                // Customer Type Filter Logic
                const custType = (wo.customer_type || wo.customerType || "REGULER").toUpperCase();
                const matchesCustType = selectedCustTypes.length === 0 || selectedCustTypes.some(ct => custType.includes(ct.replace("HVC ", "")));

                let matchesDate = true;
                if (dateFilter && (wo.reported_date || wo.reportedDate)) {
                    const woDate = new Date(wo.reported_date || wo.reportedDate).toISOString().slice(0, 10);
                    matchesDate = woDate === dateFilter;
                } else if (dateFilter) {
                    matchesDate = false;
                }

                // Status Filter Logic - Multi-select
                let matchesStatus = true;
                const ageHours = getTicketAgeHours(wo);
                if (selectedStatuses.length > 0) {
                    matchesStatus = selectedStatuses.some(sel => {
                        if (sel === "expired") return ageHours > 24 && !closedStatuses.includes(status);
                        if (sel === "nearExpired") return ageHours >= 12 && ageHours <= 24 && !closedStatuses.includes(status);
                        if (sel === "active") return ageHours < 12 && !closedStatuses.includes(status);
                        if (sel === "closed") return closedStatuses.includes(status);
                        return false;
                    });
                }

                // Technician filter
                let matchesTech = true;
                if (window.activeTechFilter) {
                    const assigned = wo.assigned_to || wo.assignedTo;
                    if (assigned && assigned !== '[]' && assigned !== '') {
                        try {
                            const parsed = typeof assigned === 'string' ? JSON.parse(assigned) : assigned;
                            const techs = Array.isArray(parsed) ? parsed : [parsed];
                            matchesTech = techs.some(t => {
                                const name = typeof t === 'object' ? (t.nama || t.name) : t;
                                return name === window.activeTechFilter;
                            });
                        } catch (e) {
                            matchesTech = false;
                        }
                    } else {
                        matchesTech = false;
                    }
                }

                // HD filter
                let matchesHd = true;
                if (window.activeHdFilter) {
                    matchesHd = wo.assigned_by === window.activeHdFilter || wo.last_update_by === window.activeHdFilter;
                }

                return matchesSearch && matchesSegment && matchesSource && matchesStatus && matchesWorkzone && matchesCustType && matchesDate && matchesTech && matchesHd;
            });

            // Sort so active tickets are at the top
            window.filteredWorkOrders.sort((a, b) => {
                const aStatus = (a.status || a.TicketStatus || "").toUpperCase();
                const bStatus = (b.status || b.TicketStatus || "").toUpperCase();
                const aClosed = closedStatuses.includes(aStatus);
                const bClosed = closedStatuses.includes(bStatus);
                if (aClosed && !bClosed) return 1;
                if (!aClosed && bClosed) return -1;
                return 0; // Keep original order otherwise
            });

            window.currentPage = 1;
            window.renderWorkOrders();
        } catch (err) {
            console.error("[Dashboard] applyFilters ERROR:", err);
        }
    }

    // View state: 'open' or 'closed'
    window.currentView = 'open';

    window.fetchWorkOrders = async function() {
        const syncBtn = document.getElementById("syncNow");

        try {
            // TIDAK cleanup setiap fetch — terlalu berat (lock timeout)
            // Cleanup hanya dilakukan manual atau saat teknisi close tiket

            // Fetch from internal Astro API with view parameter
            const response = await fetch(`/api/insera-tickets?view=${window.currentView}`);
            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

            const data = await response.json();
            if (Array.isArray(data)) {
                window.allWorkOrders = data;
                console.log(`[Dashboard] Fetched ${window.allWorkOrders.length} ${window.currentView} records. Refreshing UI...`);
                window.applyFilters();
                window.updateStats();
                window.fetchTechStats && window.fetchTechStats();

                // Update Last Sync UI
                const lastSyncEl = document.getElementById("lastSyncInfo");
                if (lastSyncEl) {
                    lastSyncEl.textContent = "Last checked: " + new Date().toLocaleTimeString("id-ID");
                }
            }
        } catch (error) {
            console.error("Failed to fetch work orders via internal API:", error);
            // If API fails, ensure we still have what we started with
            if (window.allWorkOrders.length === 0 && initialWorkOrders.length > 0) {
                window.allWorkOrders = [...initialWorkOrders];
                window.applyFilters();
            }
        } finally {
            if (syncBtn) syncBtn.classList.remove("animate-spin");
        }
    }

    // Toggle view function
    window.toggleView = function() {
        window.currentView = window.currentView === 'open' ? 'closed' : 'open';
        const viewLabel = document.getElementById('viewLabel');
        const toggleBtn = document.getElementById('toggleViewBtn');

        if (viewLabel) viewLabel.textContent = `View: ${window.currentView === 'open' ? 'Open' : 'Closed'}`;
        if (toggleBtn) {
            if (window.currentView === 'closed') {
                toggleBtn.classList.add('bg-amber-500/10', 'text-amber-600', 'border-amber-500/30');
            } else {
                toggleBtn.classList.remove('bg-amber-500/10', 'text-amber-600', 'border-amber-500/30');
            }
        }

        window.fetchWorkOrders();
    }


    window.openEditModal = async function (id) {
        try {
            const response = await fetch(`/api/insera-tickets?id=${id}`);
            const wo = await response.json();


            if (wo.error || wo.status === "error") {
                alert(wo.error || wo.message);
                return;
            }

            // Populate form
            document.getElementById("editId").value = id.toString();
            document.getElementById("editOrderId").value = wo.order_id || wo.orderId || "";
            document.getElementById("editCustomerType").value = wo.customer_type || wo.customerType || "REGULER";
            document.getElementById("editTicketType").value = wo.ticket_type || wo.ticketType || "REGULER";
            document.getElementById("editSummary").value = wo.summary || wo.title || wo.description || "";
            document.getElementById("editContactPhone").value = wo.contact_phone || wo.contactPhone || "";
            document.getElementById("editServiceNo").value = wo.service_no || wo.serviceNo || "";
            document.getElementById("editTeam").value = wo.team || "";
            document.getElementById("editWorkzone").value = wo.workzone || wo.workZone || "";
            document.getElementById("editNotesHd").value = wo.notes_hd || wo.notesHd || "";


            const reportedDate = wo.reported_date || wo.reportedDate;
            if (reportedDate) {
                const rd = new Date(reportedDate);
                if (!isNaN(rd)) document.getElementById("editReportedDate").value = rd.toISOString().slice(0, 16);
            }
            const bookingDate = wo.booking_date || wo.bookingDate;
            if (bookingDate) {
                const bd = new Date(bookingDate);
                if (!isNaN(bd)) document.getElementById("editBookingDate").value = bd.toISOString().slice(0, 16);
            }

            document.getElementById("editModal")?.classList.remove("hidden");
        } catch (error) {
            alert("Gagal memuat work order");
        }
    };

    window.openSendModal = async function (id, orderId) {
        document.getElementById("sendWorkOrderId").value = id.toString();
        document.getElementById("sendWorkOrderIdDisplay").textContent = orderId;
        // Simpan orderId juga untuk fallback lookup
        document.getElementById("sendWorkOrderId").dataset.orderId = orderId;
        
        // Fetch groups
        try {
            const res = await fetch(`${API_URL}/api/telegram-groups`);
            const data = await res.json();
            const select = document.getElementById("sendGroupSelect");
            select.innerHTML = '<option value="">-- Pilih Grup Tujuan --</option>';
            if (data.success && data.data) {
                data.data.forEach(g => {
                    const opt = document.createElement("option");
                    opt.value = g.group_id;
                    opt.textContent = g.service_area;
                    select.appendChild(opt);
                });
            }
        } catch (e) {
            console.error("Failed to fetch groups", e);
        }

        document.getElementById("sendModal")?.classList.remove("hidden");
    };


    window.sendToTelegram = async function (id, chatId) {
        if (!chatId) {
            alert("Silakan pilih grup terlebih dahulu");
            return;
        }
        try {
            // Ambil order_id dari dataset (INC...) untuk fallback lookup
            const sendIdEl = document.getElementById("sendWorkOrderId");
            const orderId = sendIdEl?.dataset?.orderId || id;

            // Cari data tiket dari allWorkOrders untuk dikirim ke BACKEND
            // (tiket mungkin sudah dihapus dari scraped_work_orders setelah assign)
            const woData = (window.allWorkOrders || []).find(w => w.id == id || w.order_id === orderId || w.orderId === orderId);

            // Parse assigned_to dari data tiket
            let assignedTo = [];
            if (woData?.assigned_to) {
                try {
                    const parsed = typeof woData.assigned_to === 'string' ? JSON.parse(woData.assigned_to) : woData.assigned_to;
                    assignedTo = Array.isArray(parsed) ? parsed : (parsed ? [parsed] : []);
                } catch (e) { assignedTo = []; }
            }

            const response = await fetch(`${API_URL}/api/workorders/${orderId}/send`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    chatId,
                    actorName: `HD - ${CURRENT_USER}`,
                    assignedTo,
                    // Kirim data tiket langsung sebagai fallback jika tidak ada di DB
                    ticket: woData ? {
                        order_id:         woData.order_id || woData.orderId,
                        service_no:       woData.service_no || woData.serviceNo,
                        contact_phone:    woData.contact_phone || woData.contactPhone,
                        customer_type:    woData.customer_type || woData.customerType,
                        workzone:         woData.workzone,
                        device_name:      woData.device_name || woData.deviceName,
                        rk_information:   woData.rk_information || woData.rkInformation,
                        summary:          woData.summary,
                        reported_date:    woData.reported_date || woData.reportedDate,
                        reported_by:      woData.reported_by || woData.reportedBy,
                        ttr_customer:     woData.ttr_customer || woData.ttrCustomer,
                        expired_date:     woData.expired_date || woData.expiredDate,
                        booking_date:     woData.booking_date || woData.bookingDate,
                        status:           woData.status,
                        assigned_by:      woData.assigned_by || woData.assignedBy,
                        service_area:     woData.service_area || woData.serviceArea,
                    } : null
                }),
            });
            const result = await response.json();

            if (result.success || result.status === 'success') {
                alert("Work order berhasil dikirim ke Telegram!");
                document.getElementById("sendModal")?.classList.add("hidden");
            } else {
                alert(result.error || result.message || "Gagal mengirim ke Telegram");
            }
        } catch (error) {
            alert("Gagal menghubungi server");
        }
    };


    window.updateWorkOrderTeam = async function (id, teamName) {
        try {
            const response = await fetch(`${API_URL}/api/workorders/${id}`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ team: teamName }),
            });

            const result = await response.json();
            if (!result.success && result.status !== "success") {
                alert("Gagal update tim: " + (result.error || result.message || "Unknown error"));
                window.fetchWorkOrders(); // revert
            } else {
                const wo = window.allWorkOrders.find((w) => w.id === id);
                if (wo) wo.team = teamName;
            }
        } catch (error) {
            alert("Gagal update tim. Periksa koneksi.");
            window.fetchWorkOrders();
        }
    };

    function closeEditModal() {
        document.getElementById("editModal")?.classList.add("hidden");
    }

    async function saveWorkOrder(e) {
        e.preventDefault();

        const id = document.getElementById("editId").value;
        const updates = {
            customer_type: document.getElementById("editCustomerType").value,
            summary: document.getElementById("editSummary").value,
            contact_phone: document.getElementById("editContactPhone").value,
            service_no: document.getElementById("editServiceNo").value,
            team: document.getElementById("editTeam").value,
            workzone: document.getElementById("editWorkzone").value,
            notes_hd: document.getElementById("editNotesHd").value,
            reported_date: document.getElementById("editReportedDate").value || null,
            booking_date: document.getElementById("editBookingDate").value || null,
        };

        try {
            const response = await fetch("/api/insera-tickets", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ action: 'update', id, actorName: CURRENT_USER, data: updates }),
            });


            const result = await response.json();

            if (result.success || result.status === 'success') {
                closeEditModal();
                window.fetchWorkOrders();
            } else {
                alert(result.error || result.message || "Gagal menyimpan (Pastikan API Workorders tersedia)");
            }
        } catch (error) {
            alert("Gagal menyimpan work order");
        }
    }

    async function deleteWorkOrder() {
        const id = document.getElementById("editId").value;

        if (!confirm("Yakin ingin menghapus work order ini?")) {
            return;
        }

        try {
            const response = await fetch("/api/insera-tickets", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ action: 'delete', id }),
            });


            const result = await response.json();

            if (result.success || result.status === 'success') {
                closeEditModal();
                window.fetchWorkOrders();
            } else {
                alert(result.error || result.message || "Gagal hapus data");
            }
        } catch (error) {
            alert("Gagal menghapus work order");
        }
    }

    let selectedNakers = [];

    // ── Bulk Select Logic ─────────────────────────────────────────────
    let bulkSelectedIds = new Set();
    let bulkSelectedNakers = [];

    console.log("[Bulk] Initializing bulk select logic...");

    function updateBulkBar() {
        const bar = document.getElementById("bulkActionBar");
        const countEl = document.getElementById("bulkSelectedCount");
        if (!bar || !countEl) return;
        if (bulkSelectedIds.size > 0) {
            bar.classList.remove("hidden");
            countEl.textContent = `${bulkSelectedIds.size} tiket dipilih`;
        } else {
            bar.classList.add("hidden");
        }
    }

    // Delegated event for bulk checkboxes (re-rendered on each renderWorkOrders)
    document.addEventListener("change", (e) => {
        const target = e.target;
        if (target.classList && target.classList.contains("bulk-checkbox")) {
            const id = parseInt(target.dataset.woId || "0");
            if (target.checked) bulkSelectedIds.add(id);
            else bulkSelectedIds.delete(id);
            updateBulkBar();
            // Sync select-all state
            const allCbs = document.querySelectorAll(".bulk-checkbox");
            const allChecked = allCbs.length > 0 && [...allCbs].every((cb) => cb.checked);
            const selectAll = document.getElementById("selectAllCheckbox");
            if (selectAll) selectAll.checked = allChecked;
        }
    });

    document.getElementById("selectAllCheckbox")?.addEventListener("change", (e) => {
        const checked = e.target.checked;
        document.querySelectorAll(".bulk-checkbox").forEach((cb) => {
            cb.checked = checked;
            const id = parseInt(cb.dataset.woId || "0");
            if (checked) bulkSelectedIds.add(id);
            else bulkSelectedIds.delete(id);
        });
        updateBulkBar();
    });

    // Re-sync checkboxes after renderWorkOrders (since DOM is replaced)
    const _origRender = window.renderWorkOrders;
    window.renderWorkOrders = function() {
        if (_origRender) _origRender();
        // Re-check previously selected
        document.querySelectorAll(".bulk-checkbox").forEach((cb) => {
            const id = parseInt(cb.dataset.woId || "0");
            if (bulkSelectedIds.has(id)) cb.checked = true;
        });
        const allCbs = document.querySelectorAll(".bulk-checkbox");
        const selectAll = document.getElementById("selectAllCheckbox");
        if (selectAll && allCbs.length > 0) {
            selectAll.checked = [...allCbs].every((cb) => cb.checked);
        }
    };

    document.getElementById("bulkClearBtn")?.addEventListener("click", () => {
        bulkSelectedIds.clear();
        document.querySelectorAll(".bulk-checkbox").forEach((cb) => {
            cb.checked = false;
        });
        const selectAll = document.getElementById("selectAllCheckbox");
        if (selectAll) selectAll.checked = false;
        updateBulkBar();
    });

    // ── Bulk Assign & Send Modal ──────────────────────────────────────
    function renderBulkNakerList(search = "") {
        const container = document.getElementById("bulkNakerListContainer");
        if (!container) return;
        const filtered = nakerList.filter(n =>
            !search ||
            n.nama.toLowerCase().includes(search.toLowerCase()) ||
            n.nik.includes(search)
        );
        container.innerHTML = filtered.map(n => `
            <label class="flex items-center gap-3 p-2 rounded-xl hover:bg-surface-container-high cursor-pointer transition-colors ${bulkSelectedNakers.includes(n.nik) ? 'bg-primary/5' : ''}">
                <div class="relative">
                    <input type="checkbox" class="sr-only peer" ${bulkSelectedNakers.includes(n.nik) ? 'checked' : ''} onchange="toggleBulkNaker('${n.nik}')" />
                    <div class="w-5 h-5 rounded border-2 border-border-color peer-checked:bg-primary peer-checked:border-primary transition-all flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-[14px] leading-none ${bulkSelectedNakers.includes(n.nik) ? '' : 'hidden'}">check</span>
                    </div>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-on-surface truncate">${n.nama}</p>
                    <p class="text-[10px] text-on-surface-variant uppercase font-bold">${n.nik} • ${n.sektor || '-'}</p>
                </div>
            </label>
        `).join("");
    }

    window.toggleBulkNaker = function(nik) {
        const idx = bulkSelectedNakers.indexOf(nik);
        if (idx >= 0) bulkSelectedNakers.splice(idx, 1);
        else bulkSelectedNakers.push(nik);
        renderBulkNakerList(document.getElementById("bulkNakerSearch")?.value || "");
        updateBulkPreview();
    };

    function buildBulkPreviewMsg() {
        const selectedWOs = (window.allWorkOrders || []).filter(wo => bulkSelectedIds.has(wo.id));
        const assignedNames = nakerList.filter(n => bulkSelectedNakers.includes(n.nik));
        if (selectedWOs.length === 0) return "(Belum ada tiket dipilih)";

        const sep = "━━━━━━━━━━━━━━━━";
        let msg = `🔔 MORENA TICKET ALERT 🔔\n${sep}\n`;

        selectedWOs.forEach((wo, idx) => {
            const now = new Date();
            const reported = wo.reported_date || wo.reportedDate;
            let ticketAge = "-";
            if (reported) {
                const diffMs = now - new Date(reported);
                const h = Math.floor(diffMs / (1000 * 60 * 60));
                const m = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
                ticketAge = `${h}h ${m}m`;
            }
            const typeMatch = (wo.summary || "").match(/\[(.*?)\]/);
            const ticketType = typeMatch ? typeMatch[1] : (wo.ticket_type || "REGULER");
            const tier = wo.customer_type || "REGULER";

            msg += `${idx + 1}. 📋 INC ID: ${wo.order_id || wo.orderId || '-'}  \n`;
            msg += `📞 No Internet: ${wo.service_no || wo.serviceNo || '-'}\n`;
            msg += `⚙️ Status: ASSIGNED\n`;
            msg += `🏆 Tier: 🥇 ${tier} \n`;
            msg += `🎫 Tipe Tiket: ${ticketType}\n`;
            msg += `📱 CP: ${wo.contact_phone || wo.contactPhone || '-'}\n`;
            msg += `📍 Workzone: ${wo.workzone || '-'}\n`;
            msg += `📡 ODP: ${wo.device_name || wo.deviceName || '-'}\n`;
            msg += `🏢 ODC: ${wo.rk_information || wo.rkInformation || '-'}\n`;
            msg += `⏱️ Umur Tiket: ${ticketAge}\n`;
            msg += `${sep}\n`;
            msg += `📝 Summary:\n${wo.summary || '-'}  \n`;
            msg += `${sep}\n`;
        });

        msg += `👤 ASSIGNED BY: HD - ${CURRENT_USER}\n`;
        msg += `👥 ASSIGNED TO:\n`;
        assignedNames.forEach((n, i) => {
            msg += `${i + 1}. ${n.nama}${n.tag_telegram ? '@' + n.tag_telegram.replace('@','') : ''}\n`;
        });
        msg += `${sep}\n`;
        msg += `Teknisi Yang Di Assign Tiket ini Dapat Mengupdate/Close Tiketnya melalui MY TICKET pada Bot Morena Terimakasih ^^`;
        return msg;
    }

    function updateBulkPreview() {
        const previewEl = document.getElementById("bulkMsgPreview");
        if (previewEl && !previewEl.classList.contains("hidden")) {
            previewEl.textContent = buildBulkPreviewMsg();
        }
    }

    document.getElementById("togglePreviewBtn")?.addEventListener("click", () => {
        const previewEl = document.getElementById("bulkMsgPreview");
        const btn = document.getElementById("togglePreviewBtn");
        if (!previewEl || !btn) return;
        if (previewEl.classList.contains("hidden")) {
            previewEl.classList.remove("hidden");
            previewEl.textContent = buildBulkPreviewMsg();
            btn.textContent = "Sembunyikan";
        } else {
            previewEl.classList.add("hidden");
            btn.textContent = "Tampilkan";
        }
    });

    document.getElementById("bulkNakerSearch")?.addEventListener("input", (e) => {
        renderBulkNakerList(e.target.value);
    });

    document.getElementById("bulkAssignSendBtn")?.addEventListener("click", () => {
        if (bulkSelectedIds.size === 0) return;
        bulkSelectedNakers = [];
        // Populate ticket list
        const selectedWOs = (window.allWorkOrders || []).filter(wo => bulkSelectedIds.has(wo.id));
        const ticketListEl = document.getElementById("bulkTicketList");
        if (ticketListEl) {
            ticketListEl.innerHTML = selectedWOs.map(wo => `
                <div class="flex items-center gap-2 px-3 py-1.5 bg-surface-container-high rounded-lg">
                    <span class="material-symbols-outlined text-primary text-[14px]">confirmation_number</span>
                    <span class="font-mono text-xs font-bold text-primary">${wo.order_id || wo.orderId}</span>
                    <span class="text-[10px] text-on-surface-variant truncate flex-1">${(wo.summary || '').substring(0, 40)}${(wo.summary || '').length > 40 ? '...' : ''}</span>
                </div>
            `).join("");
        }
        const subtitleEl = document.getElementById("bulkModalSubtitle");
        if (subtitleEl) subtitleEl.textContent = `${bulkSelectedIds.size} tiket dipilih`;
        // Reset preview
        const previewEl = document.getElementById("bulkMsgPreview");
        if (previewEl) { previewEl.classList.add("hidden"); }
        const toggleBtn = document.getElementById("togglePreviewBtn");
        if (toggleBtn) toggleBtn.textContent = "Tampilkan";
        renderBulkNakerList();
        document.getElementById("bulkAssignModal")?.classList.remove("hidden");
    });

    function closeBulkModal() {
        document.getElementById("bulkAssignModal")?.classList.add("hidden");
    }

    document.getElementById("closeBulkModal")?.addEventListener("click", closeBulkModal);
    document.getElementById("cancelBulkBtn")?.addEventListener("click", closeBulkModal);
    document.getElementById("bulkAssignModal")?.addEventListener("click", (e) => {
        if (e.target === document.getElementById("bulkAssignModal")) closeBulkModal();
    });

    document.getElementById("saveBulkAssignBtn")?.addEventListener("click", async () => {
        if (bulkSelectedIds.size === 0) { alert("Tidak ada tiket yang dipilih"); return; }
        if (bulkSelectedNakers.length === 0) { alert("Pilih minimal 1 teknisi"); return; }

        const btn = document.getElementById("saveBulkAssignBtn");
        if (!btn) return;
        const originalContent = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Memproses...';

        const fullAssigned = nakerList.filter(n => bulkSelectedNakers.includes(n.nik)).map(n => ({
            nik: n.nik,
            nama: n.nama,
            sektor: n.sektor,
            tag_telegram: n.tag_telegram
        }));

        const selectedWOs = (window.allWorkOrders || []).filter(wo => bulkSelectedIds.has(wo.id));

        try {
            const response = await fetch("/api/insera-tickets", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: 'bulk_assign_send',
                    ids: [...bulkSelectedIds],
                    assignedTo: fullAssigned,
                    assignedBy: CURRENT_USER,
                    tickets: selectedWOs
                }),
            });

            const result = await response.json();
            if (result.success || result.status === 'success') {
                closeBulkModal();
                bulkSelectedIds.clear();
                document.querySelectorAll(".bulk-checkbox").forEach((cb) => {
                    cb.checked = false;
                });
                const selectAll = document.getElementById("selectAllCheckbox");
                if (selectAll) selectAll.checked = false;
                updateBulkBar();
                window.fetchWorkOrders();
                alert(`✅ Berhasil assign ${selectedWOs.length} tiket dan kirim notifikasi Telegram!`);
            } else {
                alert(result.error || result.message || "Gagal bulk assign");
            }
        } catch (error) {
            alert("Gagal: " + error.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalContent;
        }
    });
    // ── End Bulk Logic ────────────────────────────────────────────────

    window.openAssignModal = function(id, orderId) {
        document.getElementById("assignWorkOrderId").value = id;
        document.getElementById("assignOrderIdDisplay").textContent = orderId;
        
        const wo = window.allWorkOrders.find(w => w.id === id);
        if (wo) {
            let current = [];
            try {
                if (wo.assigned_to) {
                    const parsed = typeof wo.assigned_to === 'string' ? JSON.parse(wo.assigned_to) : wo.assigned_to;
                    current = Array.isArray(parsed) ? parsed : (parsed ? [parsed] : []);
                }
            } catch (e) { current = []; }
            selectedNakers = current.map(a => typeof a === 'object' ? (a.nik || a.id) : a);
        } else {
            selectedNakers = [];
        }
        
        renderNakerList();
        document.getElementById("assignModal").classList.remove("hidden");
    };

