        // ── Real-time Ticket Age Timer ──────────────────────────────────
        function updateAllTicketAges() {
            const elements = document.querySelectorAll(".ticket-age");
            const now = new Date();
            
            elements.forEach(el => {
                const reportedStr = el.dataset.reported;
                if (!reportedStr) {
                    el.textContent = "--:--:--";
                    return;
                }
                
                try {
                    const reported = new Date(reportedStr);
                    const diffMs = now - reported;
                    
                    if (diffMs < 0) {
                        el.textContent = "00:00:00";
                        return;
                    }
                    
                    const totalSec = Math.floor(diffMs / 1000);
                    const hours = Math.floor(totalSec / 3600);
                    const mins = Math.floor((totalSec % 3600) / 60);
                    const secs = totalSec % 60;
                    
                    const hStr = hours.toString().padStart(2, "0");
                    const mStr = mins.toString().padStart(2, "0");
                    const sStr = secs.toString().padStart(2, "0");
                    
                    el.textContent = `${hStr}:${mStr}:${sStr}`;
                    
                    // Add subtle color coding based on age (optional premium touch)
                    if (hours >= 12) el.style.color = "var(--error)";
                    else if (hours >= 4) el.style.color = "#ffca28"; // Amber
                    else el.style.color = "";
                } catch (e) {
                    el.textContent = "ERR";
                }
            });
        }

        // Start timer
        setInterval(updateAllTicketAges, 1000);
        updateAllTicketAges();
