    window.toggleNakerSelection = function(nik) {
        const idx = selectedNakers.indexOf(nik);
        if (idx >= 0) selectedNakers.splice(idx, 1);
        else selectedNakers.push(nik);
        // Refresh styles without full re-render if possible, but list is small so full is fine
