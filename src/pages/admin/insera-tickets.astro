    // ── Workzone Filter Panel ─────────────────────────────────────────
    function renderWorkzoneCheckboxes(search = "") {
        const list = document.getElementById("workzoneCheckboxList");
        if (!list) return;
        
        const filtered = ALL_WORKZONES.filter(wz => wz.toLowerCase().includes(search.toLowerCase()));
        
        list.innerHTML = filtered.map(wz => `
            <label class="flex items-center gap-3 cursor-pointer group py-1">
                <div class="relative">
                    <input type="checkbox" data-wz="${wz}" ${selectedWorkzones.includes(wz) ? "checked" : ""} class="sr-only peer" />
                    <div class="w-4 h-4 rounded border border-border-color bg-surface-container-high peer-checked:bg-primary peer-checked:border-primary transition-all flex items-center justify-center">
                        <span class="material-symbols-outlined text-white text-[10px] leading-none ${selectedWorkzones.includes(wz) ? "" : "hidden"}">check</span>
                    </div>
                </div>
                <span class="text-xs font-bold text-on-surface group-hover:text-primary transition-colors">${wz}</span>
            </label>
        `).join("");

        list.querySelectorAll("input[data-wz]").forEach(chk => {
