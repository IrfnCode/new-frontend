            <div class="px-8 py-2 bg-surface-container-high border-b border-border-color flex items-center justify-between text-[10px] font-bold tracking-wider uppercase">
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-1.5">
                        <span class="text-on-surface-variant">DB Status:</span>
                        <span class={dbError ? "text-error" : "text-emerald-500"}>
                            {dbError ? "Error / Disconnected" : "Connected (127.0.0.1)"}
                        </span>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="text-on-surface-variant">Table Source:</span>
                        <span class="text-primary">scraped_work_orders</span>
