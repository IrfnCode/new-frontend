---
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../components/Sidebar.astro";

const role = Astro.cookies.get("admin_role")?.value;
// Hanya ADMIN, KORLAP, HSA yang boleh akses groups
if (role !== "ADMIN" && role !== "KORLAP" && role !== "HSA" && role !== "HD KORLAP") {
    return Astro.redirect("/admin/tickets");
}
---

<Layout title="MORENA Admin - Group Settings">
    <div class="flex min-h-screen font-body relative overflow-x-hidden">
        <Sidebar activePage="groups" />

        <!-- Main Content Area -->
        <main
            class="ml-[256px] flex-1 flex flex-col min-h-screen bg-surface transition-all duration-500 ease-[cubic-bezier(0.87,0,0.13,1)]"
        >
            <!-- TopNavBar Shell -->
            <header
                class="sticky top-0 z-40 flex justify-between items-center px-8 py-4 w-full bg-surface/70 backdrop-blur-lg border-b border-border-color"
            >
                <div class="flex items-center gap-8">
                    <h2
                        class="text-xl font-extrabold text-primary font-headline tracking-tight"
                    >
                        MORENA Configuration
                    </h2>
                    <div class="hidden md:flex relative group">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant"
                            >search</span
                        >
                        <input
                            id="searchInput"
                            class="pl-10 pr-4 py-2 bg-surface-container-high rounded-full border-none focus:ring-2 focus:ring-primary/20 text-sm w-64 transition-all"
                            placeholder="Search service area..."
                            type="text"
                        />
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button
                        onclick="window.toggleTheme()"
                        class="p-2 rounded-full hover:opacity-80 transition-opacity text-on-surface-variant"
                    >
                        <span class="material-symbols-outlined">dark_mode</span>
                    </button>
                    <button
                        id="addGroupBtn"
                        class="bg-primary text-white px-6 py-2.5 rounded-full font-bold flex items-center gap-2 shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all"
                    >
                        <span class="material-symbols-outlined text-sm"
                            >add_link</span
                        >
                        <span>Link New Group</span>
                    </button>
                </div>
            </header>

            <!-- Configuration Content Area -->
            <div class="p-8 space-y-8">
                <!-- Guidance Banner -->
                <div
                    class="p-6 bg-primary-container/10 rounded-2xl border border-primary/20 flex gap-5"
                >
                    <div
                        class="w-12 h-12 bg-primary/20 rounded-xl flex items-center justify-center text-primary shrink-0"
                    >
                        <span class="material-symbols-outlined text-2xl"
                            >lightbulb</span
                        >
                    </div>
                    <div>
                        <h4 class="font-bold text-primary mb-1">
                            Telegram Integration Guide
                        </h4>
                        <p
                            class="text-sm text-on-surface-variant leading-relaxed"
                        >
                            Map your Telegram group IDs to specific service
                            areas. The bot will automatically route tickets to
                            the corresponding group based on the technician's
                            assigned area. Use unique IDs (usually starting with
                            -100).
                        </p>
                    </div>
                </div>

                <!-- Group Configuration Table -->
                <div
                    class="bg-surface-container-lowest rounded-2xl shadow-sm border border-border-color overflow-hidden"
                >
                    <div
                        class="p-6 border-b border-border-color flex justify-between items-center bg-surface-container-low/30"
                    >
                        <h3 class="font-headline font-bold text-lg">
                            Routing Map
                        </h3>
                        <div class="flex items-center gap-2">
                            <span
                                class="text-[10px] font-bold text-emerald-600 bg-emerald-100 px-2 py-0.5 rounded uppercase"
                                >Active Gateway</span
                            >
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low/50">
                                    <th
                                        class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-on-surface-variant"
                                        >Area Unit</th
                                    >
                                    <th
                                        class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-on-surface-variant"
                                        >Telegram Gateway ID</th
                                    >
                                    <th
                                        class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-on-surface-variant"
                                        >Network Status</th
                                    >
                                    <th
                                        class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-on-surface-variant text-right"
                                        >Actions</th
                                    >
                                </tr>
                            </thead>
                            <tbody
                                class="divide-y divide-border-color text-on-surface"
                                id="groupTableBody"
                            >
                                <tr
                                    ><td
                                        colspan="4"
                                        class="px-6 py-14 text-center text-on-surface-variant"
                                        >Initializing system map...</td
                                    ></tr
                                >
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Configuration Modal Shell -->
    <div
        id="groupModal"
        class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-on-surface/50 backdrop-blur-sm hidden"
    >
        <div
            class="bg-surface w-full max-w-lg rounded-2xl shadow-2xl border border-border-color overflow-hidden transform transition-all"
        >
            <div
                class="px-8 py-6 border-b border-border-color flex justify-between items-center bg-surface-container-low/30"
            >
                <div class="flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary"
                    >
                        <span class="material-symbols-outlined">hub</span>
                    </div>
                    <h3 class="text-xl font-bold font-headline" id="modalTitle">
                        Gateway Configuration
                    </h3>
                </div>
                <button
                    class="close-btn text-on-surface-variant hover:text-error transition-colors"
                >
                    <span class="material-symbols-outlined text-2xl">close</span
                    >
                </button>
            </div>
            <form id="groupForm" class="p-8 space-y-6">
                <input type="hidden" name="action" id="action" value="add" />
                <input type="hidden" name="id" id="edit_id" />
                <div class="space-y-4">
                    <div class="space-y-1">
                        <label
                            class="text-xs font-bold text-on-surface-variant uppercase tracking-wider"
                            >Service Area Name</label
                        >
                        <input
                            type="text"
                            name="service_area"
                            id="service_area"
                            required
                            placeholder="e.g., Sagulung Center"
                            class="w-full bg-surface-container-high rounded-xl border-none focus:ring-2 focus:ring-primary/20 p-4 text-sm font-medium"
                        />
                    </div>
                    <div class="space-y-1">
                        <label
                            class="text-xs font-bold text-on-surface-variant uppercase tracking-wider"
                            >Group ID Telegram</label
                        >
                        <input
                            type="text"
                            name="group_id"
                            id="group_id"
                            required
                            placeholder="-100xxxxxxxxxx"
                            class="w-full bg-surface-container-high rounded-xl border-none focus:ring-2 focus:ring-primary/20 p-4 text-sm font-mono"
                        />
                    </div>
                    <div class="space-y-1">
                        <label
                            class="text-xs font-bold text-on-surface-variant uppercase tracking-wider"
                            >Operational Status</label
                        >
                        <select
                            name="is_active"
                            id="is_active"
                            class="w-full bg-surface-container-high rounded-xl border-none focus:ring-2 focus:ring-primary/20 p-4 text-sm font-bold"
                        >
                            <option value="1"
                                >✅ Enabled / Routing Active</option
                            >
                            <option value="0">❌ Disabled / Muted</option>
                        </select>
                    </div>
                </div>
                <div class="pt-4">
                    <button
                        type="submit"
                        class="w-full bg-primary text-white py-4 rounded-xl font-bold shadow-lg shadow-primary/20 hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2"
                    >
                        <span class="material-symbols-outlined text-sm"
                            >settings_input_composite</span
                        >
                        <span>Commit Configuration</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script is:inline>
        async function loadGroups() {
            const tbody = document.getElementById("groupTableBody");
            try {
                const res = await fetch("/api/get-service-area-group");
                const result = await res.json();
                if (result.status === "success") {
                    tbody.innerHTML = result.data
                        .map(
                            (g) => `
                        <tr class="hover:bg-surface-container-low transition-colors group">
                            <td class="px-6 py-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-2xl bg-secondary-container flex items-center justify-center text-secondary">
                                        <span class="material-symbols-outlined">hub</span>
                                    </div>
                                    <span class="font-bold text-on-surface">${g.service_area}</span>
                                </div>
                            </td>
                            <td class="px-6 py-6 font-mono text-xs text-primary font-bold">${g.group_id}</td>
                            <td class="px-6 py-6">
                                <span class="px-3 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-widest ${
                                    g.is_active
                                        ? "bg-emerald-100 text-emerald-700"
                                        : "bg-surface-container-high text-on-surface-variant"
                                }">
                                    ${g.is_active ? "Online" : "Hibernated"}
                                </span>
                            </td>
                            <td class="px-6 py-6 text-right">
                                <div class="flex justify-end gap-2">
                                    <button onclick='editGroup(${JSON.stringify(g).replace(/'/g, "\\'")})' class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors">
                                        <span class="material-symbols-outlined text-xl">tune</span>
                                    </button>
                                    <button onclick="deleteGroup(${g.id})" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors">
                                        <span class="material-symbols-outlined text-xl">link_off</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `,
                        )
                        .join("");
                }
            } catch (err) {
                tbody.innerHTML =
                    '<tr><td colspan="4" class="px-6 py-14 text-center text-error italic">FATAL: Handshake with configuration server failed.</td></tr>';
            }
        }

        window.editGroup = (g) => {
            document.getElementById("modalTitle").innerText =
                "Resize System Gateway";
            document.getElementById("action").value = "edit";
            document.getElementById("edit_id").value = g.id;
            document.getElementById("service_area").value = g.service_area;
            document.getElementById("group_id").value = g.group_id;
            document.getElementById("is_active").value = g.is_active;
            document.getElementById("groupModal").classList.remove("hidden");
        };

        window.deleteGroup = async (id) => {
            if (
                !confirm(
                    "Remove this entry point? Operational history will be archived but routing will cease.",
                )
            )
                return;
            const fd = new FormData();
            fd.append("action", "delete");
            fd.append("id", id);
            await fetch("/api/manage-groups", { method: "POST", body: fd });
            loadGroups();
        };

        let pollInterval;
        document.addEventListener("DOMContentLoaded", () => {
            loadGroups();
            if (pollInterval) clearInterval(pollInterval);
            pollInterval = setInterval(loadGroups, 30000);

            const addGroupBtn = document.getElementById("addGroupBtn");
            if (addGroupBtn) {
                addGroupBtn.onclick = () => {
                    document
                        .getElementById("groupModal")
                        .classList.remove("hidden");
                    document.getElementById("modalTitle").innerText =
                        "Establish New Gateway";
                    document.getElementById("groupForm").reset();
                    document.getElementById("action").value = "add";
                };
            }

            const closeBtn = document.querySelector(".close-btn");
            if (closeBtn) {
                closeBtn.onclick = () =>
                    document
                        .getElementById("groupModal")
                        .classList.add("hidden");
            }

            const searchInput = document.getElementById("searchInput");
            if (searchInput) {
                searchInput.oninput = (e) => {
                    const query = e.target.value.toLowerCase();
                    const rows =
                        document.querySelectorAll("#groupTableBody tr");
                    rows.forEach((row) => {
                        const text = row.innerText.toLowerCase();
                        row.style.display = text.includes(query) ? "" : "none";
                    });
                };
            }

            const groupForm = document.getElementById("groupForm");
            if (groupForm) {
                groupForm.onsubmit = async (e) => {
                    e.preventDefault();
                    const fd = new FormData(e.target);
                    const res = await fetch("/api/manage-groups", {
                        method: "POST",
                        body: fd,
                    });
                    const result = await res.json();
                    if (result.status === "success") {
                        document
                            .getElementById("groupModal")
                            .classList.add("hidden");
                        loadGroups();
                    } else {
                        alert("System Constraint: " + result.msg);
                    }
                };
            }
        });
    </script>
</Layout>
