---
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../components/Sidebar.astro";

const role = Astro.cookies.get("admin_role")?.value;
const username = Astro.cookies.get("admin_user")?.value || "Unknown";

// Semua role boleh lihat, tapi MEMBER hanya view
const isAdmin     = role === "ADMIN";
const isKorlapHsa = role === "KORLAP" || role === "HSA" || role === "HD KORLAP";
const isMember    = role === "MEMBER";
const canEdit     = isAdmin || isKorlapHsa;
---

<Layout title="MORENA Admin - Tickets">
    <div class="flex min-h-screen font-body relative">
        <Sidebar activePage="tickets" />

        <!-- Main Content Area -->
        <main
            class="flex-1 min-w-0 flex flex-col min-h-screen bg-surface transition-all duration-500 ease-[cubic-bezier(0.87,0,0.13,1)]"
        >
            <!-- TopNavBar Shell -->
            <header
                class="sticky top-0 z-40 flex justify-between items-center px-8 py-4 w-full bg-surface/70 backdrop-blur-lg border-b border-border-color"
            >
                <div class="flex items-center gap-8">
                    <h2 class="text-xl font-extrabold text-primary font-headline tracking-tight">
                        Operations Control
                    </h2>
                    <div class="hidden md:flex relative group">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
                        <input id="searchInput" class="pl-10 pr-4 py-2 bg-surface-container-high rounded-full border-none focus:ring-2 focus:ring-primary/20 text-sm w-96 transition-all font-bold placeholder:font-normal" placeholder="Cari ID tiket, teknisi, atau ODP..." type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button id="deleteSelectedBtn" class="bg-error/10 text-error px-4 py-2 rounded-full text-xs font-bold hover:bg-error hover:text-white transition-all flex items-center gap-2 border border-error/20">
                        <span class="material-symbols-outlined text-sm">delete</span>
                        <span>Purge Data</span>
                    </button>
                    <button id="exportBtn" class="bg-primary text-white px-6 py-2 rounded-full text-xs font-bold shadow-lg shadow-primary/20 hover:opacity-90 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">download</span>
                        <span>Export XLSX</span>
                    </button>
                </div>
            </header>

            <!-- Tickets Content Area -->
            <div class="p-8 space-y-4">
                <!-- Filters Section -->
                <div class="flex flex-col lg:flex-row gap-4 bg-surface-container-low/30 p-5 rounded-[28px] border border-border-color items-end">
                    <!-- Service Area Filter Panel -->
                    <div class="flex-1 w-full space-y-1.5 relative" id="areaFilterWrapper">
                        <label class="text-[10px] font-black text-primary uppercase tracking-[0.15em] px-1 flex items-center gap-1.5 opacity-70">
                            <span class="material-symbols-outlined text-[14px]">map</span> Filter Service Area
                        </label>
                        <button id="areaFilterBtn" class="w-full bg-surface-container-low text-on-surface border border-border-color rounded-2xl px-4 py-3 text-xs focus:outline-none focus:ring-2 focus:ring-primary/20 cursor-pointer font-bold shadow-sm flex items-center justify-between group hover:border-primary/50 transition-all">
                            <span id="areaFilterLabel">Area: Semua Area</span>
                            <span class="material-symbols-outlined text-[18px] text-on-surface-variant group-hover:text-primary transition-transform duration-300">expand_more</span>
                        </button>
                        
                        <!-- Dropdown Panel -->
                        <div id="areaFilterPanel" class="hidden absolute left-0 top-[calc(100%+8px)] z-[100] bg-surface border border-border-color rounded-2xl shadow-2xl p-4 w-full min-w-[320px]">
                            <div class="relative mb-3">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[18px] text-on-surface-variant">search</span>
                                <input id="areaSearch" type="text" class="w-full pl-10 pr-4 py-2.5 bg-surface-container-high rounded-xl border-none text-xs font-bold focus:ring-2 focus:ring-primary/20" placeholder="Cari nama area..." />
                            </div>
                            <div class="flex gap-2 mb-3">
                                <button id="areaSelectAll" class="flex-1 text-[10px] font-black py-2 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-all uppercase tracking-wider">Pilih Semua</button>
                                <button id="areaClearAll" class="flex-1 text-[10px] font-black py-2 rounded-lg bg-surface-container-high text-on-surface-variant hover:bg-surface-container-highest transition-all uppercase tracking-wider">Reset</button>
                            </div>
                            <div id="areaCheckboxList" class="space-y-0.5 max-h-[220px] overflow-y-auto custom-scrollbar pr-1">
                                <!-- Dinamis via JS -->
                            </div>
                        </div>
                    </div>

                    <!-- Date Filter -->
                    <div class="flex-1 w-full space-y-1.5">
                        <label class="text-[10px] font-black text-primary uppercase tracking-[0.15em] px-1 flex items-center gap-1.5 opacity-70">
                            <span class="material-symbols-outlined text-[14px]">calendar_today</span> Filter Tanggal
                        </label>
                        <input id="filterDate" type="date" class="w-full bg-surface-container-low text-on-surface border border-border-color rounded-2xl px-4 py-3 text-xs focus:outline-none focus:ring-2 focus:ring-primary/20 cursor-pointer font-bold shadow-sm" />
                    </div>

                    <button id="resetAllBtn" class="px-6 py-3 bg-error/10 text-error hover:bg-error hover:text-white rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all border border-error/20 h-[46px] flex items-center gap-2" onclick="window.resetAllFilters()">
                        <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                        Reset
                    </button>
                </div>

                <!-- Data Table Core -->
                <div class="bg-surface-container-lowest rounded-2xl shadow-sm border border-border-color overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low/50">
                                    <th class="px-2 py-3 border-b border-border-color w-8">
                                        <input type="checkbox" id="selectAll" class="rounded border-border-color text-primary focus:ring-primary/20" />
                                    </th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">ID</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Teknisi</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">NIK</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Area</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">No Tiket</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Source</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Cust Type</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Jenis</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">No INET</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Perbaikan</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">ODP</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Assigned To</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color whitespace-nowrap">Assigned By</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color text-center whitespace-nowrap">Status</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color text-center whitespace-nowrap">Detail</th>
                                    <th class="px-2 py-3 text-[9px] font-bold text-on-surface-variant uppercase border-b border-border-color text-center whitespace-nowrap">Aksi</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-border-color text-on-surface font-body" id="ticketTableBody">
                                <tr>
                                    <td colspan="17" class="px-6 py-24 text-center text-primary font-bold italic">
                                        <div class="flex flex-col items-center gap-4">
                                            <div class="w-10 h-10 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
                                            Loading operational data...
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="p-4 border-t border-border-color bg-surface-container-low/30 flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex items-center gap-2">
                             <span class="text-[10px] font-bold uppercase text-on-surface-variant">Show</span>
                             <select id="itemsPerPage" class="bg-surface border border-border-color rounded-xl text-xs font-bold px-3 py-1.5" onchange="window.changeItemsPerPage(this.value)">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                             </select>
                        </div>
                        <div class="flex items-center gap-3">
                            <button id="prevPageBtn" onclick="window.changePage(-1)" class="w-10 h-10 rounded-xl bg-surface border border-border-color flex items-center justify-center text-on-surface-variant hover:bg-surface-container-high disabled:opacity-30">
                                <span class="material-symbols-outlined">chevron_left</span>
                            </button>
                            <div class="flex items-center gap-1.5" id="paginationNumbers"></div>
                            <button id="nextPageBtn" onclick="window.changePage(1)" class="w-10 h-10 rounded-xl bg-surface border border-border-color flex items-center justify-center text-on-surface-variant hover:bg-surface-container-high disabled:opacity-30">
                                <span class="material-symbols-outlined">chevron_right</span>
                            </button>
                        </div>
                        <div class="text-[10px] font-black text-primary uppercase tracking-widest" id="paginationInfo">Showing 0 to 0 of 0 entries</div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal Shell -->
    <div id="detailModal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-on-surface/50 backdrop-blur-sm hidden">
        <div class="bg-surface w-full max-w-4xl rounded-[32px] shadow-2xl border border-border-color overflow-hidden flex flex-col max-h-[90vh]">
            <div class="px-10 py-6 border-b border-border-color flex justify-between items-center bg-surface-container-low/30">
                <h3 id="detailModalTitle" class="text-xl font-black text-on-surface">Data Tiket</h3>
                <button class="close-btn w-10 h-10 rounded-xl flex items-center justify-center bg-surface-container-high hover:bg-error hover:text-white transition-all">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div id="detailBody" class="p-10 overflow-y-auto custom-scrollbar flex-1 bg-surface">
                <!-- Dinamis -->
            </div>
        </div>
    </div>

    <script is:inline define:vars={{ canEdit, isMember, username }}>
        let allTickets = [];
        let configJenis = [];
        let configPerbaikan = [];

        async function loadConfigs() {
            try {
                const [rJenis, rPerbaikan] = await Promise.all([
                    fetch('/api/manage-configs?type=jenis').then(res => res.json()),
                    fetch('/api/manage-configs?type=perbaikan').then(res => res.json())
                ]);
                if (rJenis.status === 'success') configJenis = rJenis.data;
                if (rPerbaikan.status === 'success') configPerbaikan = rPerbaikan.data;
            } catch (e) { console.error("Config load failed", e); }
        }
        let filteredTickets = [];
        let selectedAreas = new Set();
        let currentPage = 1;
        let itemsPerPage = 10;
        let availableAreas = [];
        let pollInterval = null;

        async function loadTickets() {
            try {
                const formData = new FormData();
                formData.append("user_id", "");
                formData.append("include_all", "1");
                formData.append("limit", "1000"); // Ambil lebih banyak data agar mantap
                
                const res = await fetch("/api/get-tiket-user", { method: "POST", body: formData });
                const result = await res.json();
                
                if (result.status === "success" && Array.isArray(result.data)) {
                    allTickets = result.data;
                    updateFilterOptions();
                    applyFilters();
                }
            } catch (err) {
                console.error("Gagal load data:", err);
            }
        }

        function updateFilterOptions() {
            availableAreas = [...new Set(allTickets.map(t => t.service_area).filter(Boolean))].sort();
            renderAreaCheckboxes();
            updateAreaLabel();
        }

        function renderAreaCheckboxes(search = "") {
            const list = document.getElementById("areaCheckboxList");
            if (!list) return;
            const filtered = availableAreas.filter(a => (a || "").toLowerCase().includes(search.toLowerCase()));
            
            list.innerHTML = filtered.map(area => `
                <label class="flex items-center gap-3 p-2.5 rounded-xl cursor-pointer group hover:bg-primary/5 transition-all">
                    <div class="relative flex items-center">
                        <input type="checkbox" data-area="${area}" ${selectedAreas.has(area) ? "checked" : ""} class="sr-only peer" />
                        <div class="w-4.5 h-4.5 rounded-lg border-2 border-border-color bg-surface peer-checked:bg-primary peer-checked:border-primary transition-all flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-[12px] leading-none ${selectedAreas.has(area) ? "" : "hidden"}">check</span>
                        </div>
                    </div>
                    <span class="text-[11px] font-bold text-on-surface">${area}</span>
                </label>
            `).join("");

            list.querySelectorAll("input[data-area]").forEach(chk => {
                chk.onchange = () => {
                    const area = chk.dataset.area;
                    if (selectedAreas.has(area)) selectedAreas.delete(area);
                    else selectedAreas.add(area);
                    updateAreaLabel();
                    applyFilters();
                    renderAreaCheckboxes(document.getElementById("areaSearch").value);
                };
            });
        }

        function updateAreaLabel() {
            const label = document.getElementById("areaFilterLabel");
            if (!label) return;
            if (selectedAreas.size === 0) label.textContent = "Area: Semua Area";
            else if (selectedAreas.size === 1) label.textContent = `Area: ${[...selectedAreas][0]}`;
            else label.textContent = `Area: ${selectedAreas.size} Terpilih`;
        }

        window.applyFilters = (resetPage = true) => {
            let filtered = allTickets;
            const dateVal = document.getElementById("filterDate")?.value;
            const searchVal = document.getElementById("searchInput")?.value?.toLowerCase()?.trim();

            if (selectedAreas.size > 0) {
                filtered = filtered.filter(t => selectedAreas.has(t.service_area));
            }

            if (dateVal) {
                filtered = filtered.filter(t => {
                    if (!t.jam_open) return false;
                    return t.jam_open.startsWith(dateVal);
                });
            }

            if (searchVal) {
                filtered = filtered.filter(t => 
                    (t.nama?.toLowerCase().includes(searchVal)) ||
                    (t.nik_teknisi?.toLowerCase().includes(searchVal)) ||
                    (t.no_tiket?.toLowerCase().includes(searchVal)) ||
                    (t.no_inet?.toLowerCase().includes(searchVal)) ||
                    (t.id?.toString().includes(searchVal))
                );
            }

            filteredTickets = filtered;
            if (resetPage) currentPage = 1;
            renderTable();
            renderPagination();
        };

        window.resetAllFilters = () => {
            selectedAreas.clear();
            document.getElementById("filterDate").value = "";
            document.getElementById("searchInput").value = "";
            document.getElementById("areaSearch").value = "";
            updateAreaLabel();
            renderAreaCheckboxes();
            applyFilters();
        };

        function renderTable() {
            const tbody = document.getElementById("ticketTableBody");
            if (!tbody) return;

            if (filteredTickets.length === 0) {
                tbody.innerHTML = '<tr><td colspan="17" class="px-6 py-20 text-center italic text-on-surface-variant">Data Kosong.</td></tr>';
                return;
            }

            const startIdx = (currentPage - 1) * itemsPerPage;
            const dataToRender = filteredTickets.slice(startIdx, startIdx + itemsPerPage);

            tbody.innerHTML = dataToRender.map(t => {
                // Determine status
                const isClosed = t.jam_close && t.jam_close !== '0000-00-00 00:00:00';
                const statusBadge = isClosed 
                    ? '<span class="px-2 py-0.5 rounded text-[9px] font-black uppercase bg-emerald-500/10 text-emerald-600 border border-emerald-500/20">CLOSED</span>'
                    : '<span class="px-2 py-0.5 rounded text-[9px] font-black uppercase bg-amber-500/10 text-amber-600 border border-amber-500/20">OPEN</span>';
                
                // Parse assigned_to and assigned_by
                let assignedTo = '-';
                let assignedBy = '-';
                
                if (t._source === 'insera' && t.assigned_to) {
                    // For Insera tickets, parse assigned_to JSON
                    try {
                        const assigned = JSON.parse(t.assigned_to);
                        if (Array.isArray(assigned) && assigned.length > 0) {
                            assignedTo = assigned.map(a => a.nama || a.nik || '?').join(', ');
                        } else {
                            assignedTo = t.assigned_to;
                        }
                    } catch (e) {
                        assignedTo = t.assigned_to || '-';
                    }
                    assignedBy = t.assigned_by || '-';
                } else {
                    // For manual tickets, use teknisi name
                    assignedTo = t.nama || '-';
                    // For manual tickets, use placeholder since created_by doesn't exist
                    assignedBy = 'Manual Entry';
                }
                
                return `
                <tr class="hover:bg-surface-container/50 transition-colors">
                    <td class="px-2 py-2 border-b border-border-color">
                        <input type="checkbox" class="row-checkbox rounded border-border-color" value="${t.id}" />
                    </td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-bold text-primary whitespace-nowrap">#${t.id}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-bold uppercase whitespace-nowrap">${t.nama || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] text-on-surface-variant whitespace-nowrap">${t.nik_teknisi || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] uppercase font-bold text-on-surface-variant whitespace-nowrap">${t.service_area || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-black font-mono whitespace-nowrap">${t.no_tiket || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color whitespace-nowrap">
                        <span class="px-1.5 py-0.5 rounded text-[8px] font-black uppercase ${t._source === 'insera' ? 'bg-primary/10 text-primary border border-primary/20' : 'bg-surface-container-highest text-on-surface-variant'}">${t._source || 'manual'}</span>
                    </td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-bold text-on-surface-variant uppercase whitespace-nowrap">${t.customer_type || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-bold uppercase whitespace-nowrap">${t.jenis || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-mono whitespace-nowrap">${t.no_inet || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] uppercase font-bold whitespace-nowrap">${t.rca || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-medium whitespace-nowrap">${t.odp || "-"}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-bold whitespace-nowrap">${assignedTo}</td>
                    <td class="px-2 py-2 border-b border-border-color text-[9px] font-bold text-on-surface-variant whitespace-nowrap">${assignedBy}</td>
                    <td class="px-2 py-2 border-b border-border-color text-center whitespace-nowrap">${statusBadge}</td>
                    <td class="px-2 py-2 border-b border-border-color text-center whitespace-nowrap">
                        <button onclick="window.showTicketDetail(${t.id})"><span class="material-symbols-outlined text-secondary text-[16px]">assignment</span></button>
                    </td>
                    <td class="px-2 py-2 border-b border-border-color text-center whitespace-nowrap">
                        <div class="flex items-center justify-center gap-1">
                            ${canEdit ? `
                             <button onclick="window.showDetail(${t.id})" class="p-1 hover:bg-orange-500/10 text-orange-500 rounded-lg transition-colors" title="Edit Data">
                                <span class="material-symbols-outlined text-[14px]">edit</span>
                             </button>
                             <button onclick="window.returnTicket(${t.id}, '${t.no_tiket}')" class="p-1 hover:bg-error/10 text-error rounded-lg transition-colors" title="Return Ticket">
                                <span class="material-symbols-outlined text-[14px]">keyboard_return</span>
                             </button>
                            ` : `<span class="text-[9px] text-on-surface-variant/40 italic">View Only</span>`}
                        </div>
                    </td>
                </tr>
                `;
            }).join("");
        }

        window.changeItemsPerPage = (val) => { itemsPerPage = parseInt(val); applyFilters(true); };
        window.changePage = (deltaOrPage, isAbsolute = false) => {
            if (isAbsolute) currentPage = deltaOrPage;
            else currentPage += deltaOrPage;
            applyFilters(false);
        };

        window.returnTicket = async (id, noTiket) => {
            if (!confirm(`Konfirmasi RETURN tiket ${noTiket}?\nTiket akan dibuka kembali dan teknisi akan menerima notifikasi.`)) return;
            const actorName = document.querySelector('meta[name="current-user"]')?.content || "Admin";

            try {
                const res = await fetch("/api/return-tiket", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ id, actorName })
                });
                const r = await res.json();
                if (r.status === "success") {
                    alert("Tiket berhasil dikembalikan (OPEN).");
                    loadTickets();
                } else {
                    alert("Gagal: " + r.msg);
                }
            } catch (e) {
                alert("Galat jaringan saat mereturn tiket.");
            }
        };

        function renderPagination() {
            const total = filteredTickets.length;
            const maxPage = Math.ceil(total / itemsPerPage) || 1;
            const start = total === 0 ? 0 : (currentPage - 1) * itemsPerPage + 1;
            const end = Math.min(currentPage * itemsPerPage, total);

            document.getElementById("paginationInfo").innerText = `Showing ${start} to ${end} of ${total}`;
            document.getElementById("prevPageBtn").disabled = currentPage === 1;
            document.getElementById("nextPageBtn").disabled = currentPage === maxPage;

            let pagesHtml = "";
            let startPage = Math.max(1, currentPage - 1);
            let endPage = Math.min(maxPage, currentPage + 1);
            for (let i = startPage; i <= endPage; i++) {
                pagesHtml += `<button onclick="window.changePage(${i}, true)" class="w-8 h-8 rounded-full text-[10px] font-bold ${currentPage === i ? "bg-primary text-white" : "text-on-surface-variant hover:bg-surface-container-high"}">${i}</button>`;
            }
            document.getElementById("paginationNumbers").innerHTML = pagesHtml;
        }

        // ── Modal Detail & Edit (Operational View) ─────────────────────────
        window.showDetail = async (id) => {
            const modal = document.getElementById("detailModal");
            const detailBody = document.getElementById("detailBody");
            modal.classList.remove("hidden");
            detailBody.innerHTML = '<div class="py-20 text-center text-primary animate-pulse font-black uppercase tracking-widest">DECOMPRESSING OPERATIONAL RECORD...</div>';

            try {
                const res = await fetch(`/api/get-tiket-by-id?id=${id}`);
                const result = await res.json();
                if (result.status === "success") {
                    const t = result.data;
                    const tzOffset = new Date().getTimezoneOffset() * 60000;
                    const jOpen = t.jam_open ? new Date(new Date(t.jam_open) - tzOffset).toISOString().slice(0, 16) : "";
