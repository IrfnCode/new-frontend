                if (result.status !== "success") throw new Error("Access Denied");

                const t = result.data;
                const formatDT = (v) => v ? new Date(v).toLocaleString("id-ID", { hour12: false, day: "2-digit", month: "long", year: "numeric", hour: "2-digit", minute: "2-digit" }) : "-";

                detailBody.innerHTML = `
