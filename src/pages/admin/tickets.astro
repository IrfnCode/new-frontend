        window.saveChanges = async (id) => {
            const btn = document.querySelector("#saveBtnArea button");
            const originalContent = btn.innerHTML;
            
            // Set Loading state
            btn.disabled = true;
            btn.innerHTML = `
                <span class="material-symbols-outlined animate-spin shadow-none">sync</span>
                MENYIMPAN DATA...
            `;
            btn.classList.add("opacity-70", "cursor-not-allowed");

            const fd = new FormData();
            fd.append("tiket_id", id);
            fd.append("jenis", document.getElementById("edit_jenis").value);
            fd.append("no_inet", document.getElementById("edit_no_inet").value);
            fd.append("no_tiket", document.getElementById("edit_no_tiket").value);
            fd.append("catatan", document.getElementById("edit_catatan").value);
            fd.append("rca", document.getElementById("edit_rca").value);
            fd.append("odp", document.getElementById("edit_odp").value);
            fd.append("material_dropcore", document.getElementById("edit_material_dropcore").value);
            fd.append("material_protection", document.getElementById("edit_material_protection").value);
            fd.append("material_ps14", document.getElementById("edit_material_ps14").value);
            fd.append("material_ps18", document.getElementById("edit_material_ps18").value);
            fd.append("material_ps116", document.getElementById("edit_material_ps116").value);
            fd.append("material_odp_solid", document.getElementById("edit_material_odp_solid").value);
            fd.append("material_patchcore", document.getElementById("edit_material_patchcore").value);
            fd.append("material_adaptor", document.getElementById("edit_material_adaptor").value);
            fd.append("material_sn_ont", document.getElementById("edit_material_sn_ont").value);
            fd.append("material_sn_stb", document.getElementById("edit_material_sn_stb").value);
            try {
                const res = await fetch("/api/update-tiket", { method: "POST", body: fd });
                const r = await res.json();
                if(r.status === "success") { 
                    alert("Sukses disimpan."); 
                    loadTickets(); 
                    document.getElementById("detailModal").classList.add("hidden"); 
                } else {
                    alert("Gagal: " + r.msg);
                }
            } catch (e) { 
                alert("Galat jaringan."); 
            } finally {
                // Restore button state
                btn.disabled = false;
                btn.innerHTML = originalContent;
                btn.classList.remove("opacity-70", "cursor-not-allowed");
            }
        };

        document.addEventListener("DOMContentLoaded", () => {
             loadConfigs();
             loadTickets();
             
             const areaBtn = document.getElementById("areaFilterBtn");
             const areaPanel = document.getElementById("areaFilterPanel");
             if (areaBtn) areaBtn.onclick = (e) => { e.stopPropagation(); areaPanel.classList.toggle("hidden"); };
             document.addEventListener("click", (e) => { if (!document.getElementById("areaFilterWrapper")?.contains(e.target)) areaPanel?.classList.add("hidden"); });
             document.getElementById("areaSearch").oninput = (e) => renderAreaCheckboxes(e.target.value);
             document.getElementById("areaSelectAll").onclick = () => { availableAreas.forEach(a => selectedAreas.add(a)); updateAreaLabel(); renderAreaCheckboxes(); applyFilters(); };
             document.getElementById("areaClearAll").onclick = () => { selectedAreas.clear(); updateAreaLabel(); renderAreaCheckboxes(); applyFilters(); };
             document.getElementById("searchInput").oninput = applyFilters;
             document.getElementById("filterDate").onchange = applyFilters;
             document.querySelector(".close-btn").onclick = () => document.getElementById("detailModal").classList.add("hidden");
             document.getElementById("selectAll").onclick = (e) => { document.querySelectorAll(".row-checkbox").forEach(cb => cb.checked = e.target.checked); };
             
             document.getElementById("deleteSelectedBtn").onclick = async () => {
                 const selectedIds = Array.from(document.querySelectorAll(".row-checkbox:checked")).map(cb => parseInt(cb.value));
                 if (selectedIds.length === 0) {
                     alert("Pilih minimal satu tiket untuk dihapus.");
                     return;
                 }
                 if (!confirm(`Hapus ${selectedIds.length} data tiket permanen?`)) return;
                 
                 const btn = document.getElementById("deleteSelectedBtn");
                 const rawTxt = btn.innerHTML;
                 btn.innerHTML = `<span class="material-symbols-outlined text-sm animate-spin">sync</span><span>Working...</span>`;
                 
                 try {
                     const res = await fetch("/api/delete-tiket", {
                         method: "POST",
                         headers: { "Content-Type": "application/json" },
                         body: JSON.stringify({ ids: selectedIds })
                     });
                     const data = await res.json();
                     if (data.status === "success") {
                         loadTickets();
                     } else {
                         alert("Gagal: " + data.message);
                     }
                 } catch (e) {
                     alert("Galat jaringan.");
                 } finally {
                     btn.innerHTML = rawTxt;
                     document.getElementById("selectAll").checked = false;
                 }
             };

             document.getElementById("exportBtn").onclick = async () => {
                 const res = await fetch(`/api/export-tiket?areas=${[...selectedAreas].join(",")}`);
                 const blob = await res.blob();
                 const url = window.URL.createObjectURL(blob);
                 const a = document.createElement("a");
                 a.href = url;
                 a.download = "export_admin.xlsx";
                 a.click();
             };
        });
    </script>
</Layout>

