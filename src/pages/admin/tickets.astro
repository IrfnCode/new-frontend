                            </div>
                            <div>
                                <p class="text-[9px] font-black text-primary uppercase tracking-[0.2em]">Teknisi Pelaksana</p>
                                <p class="text-[13px] font-black text-on-surface mt-0.5">${t.nama || "Unknown"}</p>
