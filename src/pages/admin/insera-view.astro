---
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../components/Sidebar.astro";
import { InseraModel } from "../../lib/models/InseraModel";
import { TechnicianModel } from "../../lib/models/TechnicianModel";

const role = Astro.cookies.get("admin_role")?.value;
const username = Astro.cookies.get("admin_user")?.value || "Unknown";

const allowedRoles = ["ADMIN", "KORLAP", "HSA", "HD KORLAP", "HELPDESK", "HD"];
if (!role || !allowedRoles.includes(role)) {
    return Astro.redirect("/admin/tickets");
}

let initialWorkOrders = [];
let technicians = [];
let dbError = null;

try {
    technicians = await TechnicianModel.getAll();
} catch (err) {
    dbError = err.message;
}
---

<Layout title="ALL TICKET LIST - INSERA View">
    <meta name="current-user" content={username} />
    <div class="flex min-h-screen font-body relative overflow-x-hidden bg-white text-black text-xs">
        <Sidebar activePage="insera-view" />

        <main class="ml-[256px] flex-1 flex flex-col min-h-screen transition-all duration-500 ease-[cubic-bezier(0.87,0,0.13,1)] overflow-x-hidden relative">
            <div class="p-4 flex flex-col gap-2">
                <!-- Header -->
                <div class="flex items-center gap-4">
                    <h1 class="text-base font-bold uppercase tracking-wide">ALL TICKET LIST</h1>
                </div>

                <!-- Top Buttons -->
                <div class="flex items-center gap-2 mb-2">
                    <button class="bg-gray-200 hover:bg-gray-300 text-gray-800 py-1 px-3 border border-gray-300 rounded text-[11px] font-semibold transition-colors">Bookmark</button>
                    <button id="saveFilterBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-800 py-1 px-3 border border-gray-300 rounded text-[11px] font-semibold transition-colors">Save Filter</button>
                    <span id="saveFilterStatus" class="text-green-600 font-bold ml-2 text-[10px] opacity-0 transition-opacity">Saved!</span>
                </div>

                <!-- Filters Section -->
                <div class="border border-gray-300 bg-[#f9f9f9] p-3 rounded-sm space-y-3 filter-container">
                    
                    <!-- Row 1 -->
                    <div class="flex flex-wrap items-center gap-3">
                        <div class="flex items-center gap-1">
                            <select id="f_limit" class="border border-gray-300 p-1 text-[11px] outline-none">
                                <option value="100">100</option>
                                <option value="500">500</option>
                                <option value="1000">1000</option>
                            </select>
                            <span class="text-[10px] text-gray-600">Items</span>
                        </div>
                        
                        <div class="flex items-center gap-1">
                            <label class="text-[10px] text-gray-600 font-semibold w-24 text-right">Reported Date</label>
                            <input type="datetime-local" id="f_reported_date_from" class="border border-gray-300 p-1 text-[10px] outline-none w-36" />
                            <span>-</span>
                            <input type="datetime-local" id="f_reported_date_to" class="border border-gray-300 p-1 text-[10px] outline-none w-36" />
                        </div>

                        <div class="flex items-center gap-1">
                            <label class="text-[10px] text-gray-600 font-semibold w-20 text-right uppercase">Status Date</label>
                            <input type="datetime-local" id="f_status_date_from" class="border border-gray-300 p-1 text-[10px] outline-none w-36" placeholder="From" />
                            <span>-</span>
                            <input type="datetime-local" id="f_status_date_to" class="border border-gray-300 p-1 text-[10px] outline-none w-36" placeholder="To" />
                        </div>

                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_witel_sumb" class="bg-transparent border-none outline-none text-[10px] w-32 placeholder-gray-400" placeholder="TIF FEB DISTRICT SUMB" />
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">search</span>
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">delete</span>
                        </div>

                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_owner" class="bg-transparent border-none outline-none text-[10px] w-24 placeholder-gray-400" placeholder="OWNER" />
                        </div>

                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_priority" class="bg-transparent border-none outline-none text-[10px] w-28 placeholder-gray-400" placeholder="REPORTED PRIORITY" />
                        </div>
                        
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_customer" class="bg-transparent border-none outline-none text-[10px] w-24 placeholder-gray-400" placeholder="CUSTOMER" />
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">search</span>
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">delete</span>
                        </div>
                        
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_ext_ticket" class="bg-transparent border-none outline-none text-[10px] w-32 placeholder-gray-400" placeholder="EXTERNAL TICKET ID" />
                        </div>
                    </div>

                    <!-- Row 2 -->
                    <div class="flex flex-wrap items-center gap-4">
