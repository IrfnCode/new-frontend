                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">delete</span>
                        </div>
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_service_number" class="bg-transparent border-none outline-none text-[10px] w-32 placeholder-gray-400" placeholder="SERVICE NUMBER" />
                        </div>
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_service_type" class="bg-transparent border-none outline-none text-[10px] w-24 placeholder-gray-400" placeholder="SERVICE TYPE" />
