                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_customer_id" class="bg-transparent border-none outline-none text-[10px] w-24 placeholder-gray-400" placeholder="CUSTOMER ID" />
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">search</span>
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">delete</span>
                        </div>
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <select id="f_related_gamas" class="bg-transparent border-none outline-none text-[10px] w-36 text-gray-600">
                                <option value="">RELATED TO GAMAS</option>
                                <option value="YES">YES</option>
                                <option value="NO">NO</option>
                            </select>
                        </div>
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_ticket_id_gamas" class="bg-transparent border-none outline-none text-[10px] w-32 placeholder-gray-400" placeholder="TICKET ID GAMAS" />
                        </div>
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_guarante_status" class="bg-transparent border-none outline-none text-[10px] w-32 placeholder-gray-400" placeholder="GUARANTE STATUS" />
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">search</span>
                            <span class="material-symbols-outlined text-[14px] text-gray-500 cursor-pointer">delete</span>
                        </div>
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_customer_name" class="bg-transparent border-none outline-none text-[10px] w-32 placeholder-gray-400" placeholder="CUSTOMER NAME" />
                        </div>
                        <div class="flex items-center gap-1 border-b border-gray-300 pb-0.5">
                            <input type="text" id="f_contact_name" class="bg-transparent border-none outline-none text-[10px] w-28 placeholder-gray-400" placeholder="CONTACT NAME" />
                        </div>
                        
                        <div class="ml-auto flex items-center gap-2 pt-2">
                            <button id="clearFilterBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-800 py-1 px-3 border border-gray-300 rounded text-[11px] font-semibold transition-colors">Clear Filter</button>
                            <button id="minimizeBtn" class="bg-[#d9edf7] hover:bg-[#c4e3f3] text-[#31708f] py-1 px-3 border border-[#bce8f1] rounded text-[11px] font-semibold transition-colors">Minimize</button>
