        // Event delegation for expand/collapse (modern version)
        document.body.addEventListener('click', function(e) {
            const row = e.target.closest('.area-total-row');
            if (!row) return;
            
            // Skip modal trigger clicks
            if (e.target.closest('.clickable-number')) return;
            
            const tbody = row.closest('.area-group');
            if (!tbody) return;
            
            e.preventDefault();
            const isExpanded = tbody.classList.toggle('expanded');
            console.log('Toggling area:', row.innerText.trim(), 'Expanded:', isExpanded);
            
            const icon = row.querySelector('.toggle-icon');
            const iconBox = row.querySelector('.toggle-icon-box');
            
            if (icon) {
                icon.textContent = isExpanded ? 'expand_more' : 'chevron_right';
            }
            if (iconBox) {
                if (isExpanded) {
                    iconBox.classList.add('rotate-90', 'bg-amber-500', 'text-white');
                    iconBox.classList.remove('bg-primary', 'bg-orange-500');
                } else {
                    iconBox.classList.remove('rotate-90', 'bg-amber-500', 'text-white');
                    // Restore original color based on section
                    if (tbody.closest('#jenisTable')) iconBox.classList.add('bg-primary');
                    if (tbody.closest('#timeslotTable')) iconBox.classList.add('bg-orange-500');
                }
            }
            
            const teknisiRows = tbody.querySelectorAll('.teknisi-row');
            teknisiRows.forEach(r => {
                if (isExpanded) {
                    r.classList.remove('hidden');
                    r.style.display = 'table-row'; // Force display style just in case hidden conflict
                } else {
                    r.classList.add('hidden');
                    r.style.display = 'none';
                }
            });
        });

