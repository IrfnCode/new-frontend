---
import Layout from "../layouts/Layout.astro";
import { ConfigModel } from "../lib/models/ConfigModel";

const typesData = await ConfigModel.getAllJenis();
const repairsData = await ConfigModel.getAllPerbaikan();

const JENIS_LIST = typesData.map(t => t.nama_jenis);
const RCA_LIST = repairsData.map(r => r.jenis_perbaikan);
---

<Layout title="MORENA - Close Ticket" useTelegram={true}>
    <main class="min-h-screen bg-surface font-body p-4 pb-12 relative">
        <div class="fixed top-6 right-6 z-[60]">
            <button
                onclick="window.toggleTheme()"
                class="w-12 h-12 bg-surface-container-high/80 backdrop-blur-md rounded-full shadow-lg border border-border-color flex items-center justify-center text-on-surface-variant hover:text-primary transition-all active:scale-95"
            >
                <span class="material-symbols-outlined">contrast</span>
            </button>
        </div>

        <div class="max-w-xl mx-auto space-y-8">
            <!-- Header -->
            <header class="text-center pt-8 space-y-2">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-container rounded-3xl shadow-lg shadow-primary/20 mb-4 animate-pulse">
                    <span class="material-symbols-outlined text-white text-3xl" style="font-variation-settings: 'FILL' 1;">task_alt</span>
                </div>
                <h1 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase">Penyelesaian Tiket</h1>
                <p class="text-on-surface-variant text-[10px] font-bold uppercase tracking-[0.3em] opacity-60">Field Work Completion</p>
            </header>

            <!-- Loading Overlay for Initial Fetch -->
            <div id="initialLoading" class="flex flex-col items-center justify-center py-20 space-y-4">
                <div class="w-12 h-12 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-widest">Identifikasi Tiket...</p>
            </div>

            <!-- Form Card -->
            <div id="formCard" class="hidden bg-surface-container-lowest rounded-[2.5rem] shadow-2xl border border-border-color overflow-hidden animate-fade-in">
                <form id="updateForm" class="p-8 space-y-8">
                    <input type="hidden" id="tiket_id" />
                    
                    <!-- Section: Header Info -->
                    <div class="space-y-6">
                        <div class="flex items-center gap-3 border-b border-border-color pb-4">
                            <span class="material-symbols-outlined text-primary">analytics</span>
                            <h3 class="font-bold text-lg font-headline">Identitas Pekerjaan</h3>
                        </div>
                        <div class="space-y-4">
                            <div class="grid grid-cols-2 gap-4">
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest ml-1">No. Tiket (INC/WO)</label>
                                    <input type="text" id="no_tiket" class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-black text-primary-variant cursor-not-allowed opacity-80" readonly />
                                </div>
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest ml-1">ID Internet</label>
                                    <input type="text" id="no_inet" class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-black text-on-surface font-mono cursor-not-allowed opacity-80" readonly />
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest ml-1">Label ODP</label>
                                    <input type="text" id="odp" placeholder="ODP-XXX-XX/00" class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-bold" />
                                </div>
                                <div class="space-y-1">
                                    <label class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest ml-1">Kontak Pelanggan</label>
                                    <input type="tel" id="no_hp" placeholder="62813..." class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-bold" />
                                </div>
                            </div>
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest ml-1">Klasifikasi Pekerjaan</label>
                                <select id="jenis" class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-bold">
                                    {JENIS_LIST.map(j => <option value={j}>{j}</option>)}
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Section: Assignment History -->
                    <div id="assignmentAuditSection" class="space-y-6 hidden">
                        <div class="flex items-center gap-3 border-b border-border-color pb-4">
                            <span class="material-symbols-outlined text-amber-500">history</span>
                            <h3 class="font-bold text-lg font-headline">Jejak Penugasan</h3>
                        </div>
                        <div id="assignmentAuditTimeline" class="space-y-4 max-h-[250px] overflow-y-auto px-2">
                            <!-- Injected here -->
                        </div>
                    </div>

                    <!-- Section: Materials -->
                    <div class="space-y-6">
                        <div class="flex items-center gap-3 border-b border-border-color pb-4">
                            <span class="material-symbols-outlined text-primary">inventory_2</span>
                            <h3 class="font-bold text-lg font-headline">Logistik & Material</h3>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                             {[
                                { id: 'material_dropcore', label: 'Dropcore (M)' },
                                { id: 'material_protection', label: 'Protection' },
                                { id: 'material_ps14', label: 'PS 1:4' },
                                { id: 'material_ps18', label: 'PS 1:8' },
                                { id: 'material_ps116', label: 'PS 1:16' },
                                { id: 'material_odp_solid', label: 'ODP Solid' },
                                { id: 'material_patchcore', label: 'Patchcore' },
                                { id: 'material_adaptor', label: 'Adaptor' }
                             ].map(m => (
                                <div class="space-y-1">
                                    <label class="text-[9px] font-bold text-on-surface-variant uppercase ml-2">{m.label}</label>
                                    <input type="number" id={m.id} value="0" min="0" class="w-full bg-surface-container-low rounded-xl border border-border-color p-3 text-center font-black text-sm" />
                                </div>
                             ))}
                        </div>
                        <div class="space-y-4 pt-2">
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-primary uppercase tracking-widest ml-2 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[14px]">barcode_scanner</span>
                                    SN ONT
                                </label>
                                <input type="text" id="material_sn_ont" placeholder="Contoh: ZTEGC1234567" class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-mono font-bold text-primary" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-primary uppercase tracking-widest ml-2 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-[14px]">barcode_scanner</span>
                                    SN STB
                                </label>
                                <input type="text" id="material_sn_stb" placeholder="Contoh: SN-STB-123..." class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-mono font-bold text-primary" />
                            </div>
                        </div>
                    </div>

                    <!-- Section: Completion Details -->
                    <div class="space-y-6">
                        <div class="flex items-center gap-3 border-b border-border-color pb-4">
                            <span class="material-symbols-outlined text-primary">assignment_turned_in</span>
                            <h3 class="font-bold text-lg font-headline">Hasil Pemeriksaan</h3>
                        </div>
                        <div class="space-y-4">
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest ml-1">RCA (Analisa Kerusakan) <span class="text-error font-bold">*</span></label>
                                <select id="rca" class="w-full bg-surface-container-high rounded-xl border-none p-4 text-sm font-bold" required>
                                    <option value="">Pilih RCA...</option>
                                    {RCA_LIST.map(r => <option value={r}>{r}</option>)}
                                </select>
                            </div>
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest ml-1">Catatan Pengerjaan</label>
                                <textarea id="catatan" placeholder="Detail perbaikan..." class="w-full bg-surface-container-high rounded-2xl border-none p-4 text-sm min-h-[120px] font-medium"></textarea>
                            </div>
                        </div>
                    </div>

                    <button type="button" id="submitBtn" class="w-full bg-primary text-white py-5 rounded-[2rem] font-black text-xl shadow-2xl shadow-primary/30 active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                        <span class="material-symbols-outlined text-3xl">task_alt</span>
                        <span>CLOSE TIKET</span>
                    </button>
                </form>
            </div>
        </div>

        <!-- Feedback Overlays -->
        <div id="loadingOverlay" class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-on-surface/80 backdrop-blur-md text-white space-y-4 hidden">
            <div class="w-16 h-16 border-4 border-white/20 border-t-white rounded-full animate-spin"></div>
            <p class="font-black tracking-widest text-sm uppercase">Sinkronisasi Server...</p>
        </div>

        <div id="resultOverlay" class="fixed inset-0 z-[110] flex items-center justify-center p-6 bg-on-surface/50 backdrop-blur-sm hidden">
            <div class="bg-surface w-full max-w-sm rounded-[3rem] shadow-2xl border border-border-color p-10 text-center space-y-6">
                <div id="resultIcon" class="w-24 h-24 mx-auto bg-primary/10 rounded-full flex items-center justify-center text-6xl shadow-inner shadow-primary/10">✅</div>
                <div class="space-y-2">
                    <h2 id="resultTitle" class="text-2xl font-black font-headline tracking-tighter text-on-surface">BERHASIL</h2>
                    <p id="resultMessage" class="text-on-surface-variant text-sm font-medium leading-relaxed opacity-80"></p>
                </div>
                <button id="resultActionBtn" class="w-full bg-primary text-white py-5 rounded-[2rem] font-bold shadow-lg hover:opacity-90 transition-opacity uppercase tracking-widest">Selesai</button>
            </div>
        </div>
    </main>

    <script is:inline>
        let tg = window.Telegram?.WebApp;
        let currentUserId = "";
        let isSubmitting = false;

        if (tg) {
            tg.ready();
            tg.expand();
            if (tg.initDataUnsafe && tg.initDataUnsafe.user) {
                currentUserId = tg.initDataUnsafe.user.id.toString();
            }
        }

        async function init() {
            const urlParams = new URLSearchParams(window.location.search);
            const id = urlParams.get('id');
            const source = urlParams.get('source') || 'manual';

            if (!id || !currentUserId) {
                showResult(false, "Akses Ilegal", "ID Tiket atau Sesi Telegram tidak ditemukan.");
                return;
            }

            try {
                const res = await fetch(`/api/get-tiket-by-id?id=${id}&source=${source}`);
                const result = await res.json();

                if (result.status === "success") {
                    const ticket = result.data;
                    
                    // Security check: 
                    // Manual source depends on user_id
                    // Insera source relies on the server-side filtering in getAssignedToUser 
                    // but here we should just ensure we got data.
                    if (source === 'manual' && ticket.user_id !== currentUserId) {
                        showResult(false, "Bukan Pemilik", "Anda tidak memiliki otoritas untuk menutup tiket ini.");
                        return;
                    }
                    
                    fillForm(ticket);
                    fetchAssignmentHistory(ticket.id);
                    document.getElementById('initialLoading').classList.add('hidden');
                    document.getElementById('formCard').classList.remove('hidden');
                } else {
                    showResult(false, "Error", "Gagal memuat detail tiket dari server.");
                }
            } catch (err) {
                showResult(false, "System Error", "Kegagalan komunikasi data: " + err.message);
            }

            document.getElementById('submitBtn').onclick = handleSubmit;
        }

        function fillForm(data) {
            document.getElementById('tiket_id').value = data.id;
            document.getElementById('no_tiket').value = data.no_tiket;
            document.getElementById('no_inet').value = data.no_inet;
            document.getElementById('odp').value = data.odp || '';
            document.getElementById('no_hp').value = data.no_hp || '';
            document.getElementById('jenis').value = data.jenis || 'REGULER';
            document.getElementById('catatan').value = data.catatan || '';
        }

        async function handleSubmit() {
            if (isSubmitting) return;
            
            const rca = document.getElementById('rca').value;
            if (!rca) {
                alert("Harap pilih RCA pengerjaan.");
                document.getElementById('rca').focus();
                return;
            }

            isSubmitting = true;
            toggleLoading(true);

            try {
                const formData = new FormData();
                const id = document.getElementById('tiket_id').value;
                const source = new URLSearchParams(window.location.search).get('source') || 'manual';

                formData.append('tiket_id', id);
                formData.append('user_id', currentUserId);
                formData.append('source', source);
                
                // Automatic jam_close to NOW
                const now = new Date();
                const nowIso = now.getFullYear() + '-' + 
                               String(now.getMonth() + 1).padStart(2, '0') + '-' + 
                               String(now.getDate()).padStart(2, '0') + ' ' + 
                               String(now.getHours()).padStart(2, '0') + ':' + 
                               String(now.getMinutes()).padStart(2, '0') + ':' + 
                               String(now.getSeconds()).padStart(2, '0');
                
                formData.append('jam_close', nowIso);
                
                // Fields
                ['jenis', 'no_inet', 'no_tiket', 'rca', 'catatan', 'odp', 'no_hp'].forEach(f => {
                    formData.append(f, document.getElementById(f).value);
                });

                // Materials
                [
                    'material_dropcore', 'material_protection', 'material_ps14', 
                    'material_ps18', 'material_ps116', 'material_odp_solid', 
                    'material_patchcore', 'material_adaptor', 'material_sn_ont', 'material_sn_stb'
                ].forEach(m => {
                    const el = document.getElementById(m);
                    if (el) formData.append(m, el.value);
                });

                const res = await fetch('/api/update-tiket', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await res.json();
                if (result.status === 'success') {
                    showResult(true, "TIKET CLOSE", "Laporan telah diselesaikan dan diarsipkan. Kerja bagus!");
                } else {
                    showResult(false, "Gagal", result.msg || "Terjadi kesalahan saat menyimpan data.");
                }
            } catch (err) {
                showResult(false, "System Error", err.message);
            } finally {
                isSubmitting = false;
                toggleLoading(false);
            }
        }

        function toggleLoading(show) {
            document.getElementById('loadingOverlay').classList.toggle('hidden', !show);
        }

        function showResult(success, title, msg) {
            document.getElementById('resultIcon').innerText = success ? "✅" : "⚠️";
            document.getElementById('resultTitle').innerText = title;
            document.getElementById('resultMessage').innerText = msg;
            document.getElementById('resultOverlay').classList.remove('hidden');
            document.getElementById('resultActionBtn').onclick = () => {
                document.getElementById('resultOverlay').classList.add('hidden');
                if (success) tg?.close();
            };
        }

        async function fetchAssignmentHistory(id) {
            try {
                const res = await fetch(`/api/get-assignment-history?id=${id}`);
                const result = await res.json();
                if (result.status === "success" && result.data.length > 0) {
                    renderAuditTimeline(result.data);
                }
            } catch (e) { console.warn("Failed to fetch assignment history", e); }
        }

        function renderAuditTimeline(history) {
            const section = document.getElementById('assignmentAuditSection');
            const timeline = document.getElementById('assignmentAuditTimeline');
            if (!section || !timeline) return;

            section.classList.remove('hidden');
            timeline.innerHTML = history.map(item => `
                <div class="p-4 bg-surface-container-low rounded-2xl border border-border-color flex items-start gap-4">
                    <div class="w-8 h-8 bg-amber-500/10 rounded-full flex items-center justify-center text-amber-500 flex-shrink-0">
                        <span class="material-symbols-outlined text-[18px]">person</span>
                    </div>
                    <div class="space-y-1">
                        <p class="text-xs font-black text-on-surface">Assigned by: <span class="text-primary">${item.assigned_by}</span></p>
                        <p class="text-[10px] font-bold text-on-surface-variant opacity-70">${new Date(item.assigned_at).toLocaleString('id-ID')}</p>
                    </div>
                </div>
            `).join("");
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</Layout>
