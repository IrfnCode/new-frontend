---
const { activePage = "dashboard" } = Astro.props;
const role = Astro.cookies.get("admin_role")?.value || "HELPDESK";
const username = Astro.cookies.get("admin_user")?.value || "Admin User";
const logoSrc = "/logo-morena.png?v3";

const isAdmin    = role === "ADMIN";
const isHelpdesk = role === "HELPDESK" || role === "HD";
const isMember   = role === "MEMBER";
const isKorlap   = role === "KORLAP";
const isHsa      = role === "HSA";
const isKorlapHsa = isKorlap || isHsa || role === "HD KORLAP";

// Hak akses per fitur
const canViewDashboard    = true;
const canViewTickets      = true;
const canEditTickets      = isAdmin || isKorlapHsa || isHelpdesk;
const canViewInsera       = isAdmin || isKorlapHsa || isHelpdesk;
const canViewAnnouncement = isAdmin || isKorlapHsa || isHelpdesk;
const canViewConfigs      = isAdmin || isKorlapHsa;
const canViewAccounts     = isAdmin;
const canViewTechnicians  = isAdmin || isKorlapHsa || isHelpdesk;
---

<aside
    id="sidebar"
    class="fixed left-0 top-0 h-[100dvh] w-64 bg-surface-container-low border-r border-border-color flex flex-col z-[60] transition-all duration-500 ease-[cubic-bezier(0.87,0,0.13,1)] group/sidebar font-body"
>
    <!-- Toggle Button -->
    <button
        id="sidebarToggle"
        class="absolute -right-3 top-8 w-6 h-6 bg-primary text-white rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-all z-[70] border-2 border-surface"
    >
        <span
            class="material-symbols-outlined text-[14px] font-bold"
            id="toggleIcon">chevron_left</span
        >
    </button>

    <!-- Logo & Description Section -->
    <div class="px-8 pt-10 pb-6 flex flex-col items-start gap-1 overflow-hidden shrink-0">
        <img
            src={logoSrc}
            alt="MORENA"
            class="h-12 w-auto max-w-[170px] object-contain shrink-0"
        />
        <div class="sidebar-text opacity-100 transition-opacity duration-300 w-full">
            <p class="text-[9px] uppercase tracking-[0.1em] font-black text-primary/60 leading-tight max-w-[190px] mt-1 break-words">
                Monitoring Order Real-Time & Electronic Notice Assurance
            </p>
        </div>
    </div>

    <!-- Navigation Area -->
    <nav class="flex-1 px-4 py-4 space-y-1.5 overflow-y-auto custom-scrollbar">
        <!-- Dashboard: semua role -->
        <a
            class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "dashboard" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
            href="/admin"
        >
            <span class="material-symbols-outlined shrink-0" style={activePage === "dashboard" ? "font-variation-settings: 'FILL' 1;" : ""}>dashboard</span>
            <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Dashboard</span>
        </a>

        <!-- Data Tiket: semua role -->
        <a
            class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "tickets" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
            href="/admin/tickets"
        >
            <span class="material-symbols-outlined shrink-0" style={activePage === "tickets" ? "font-variation-settings: 'FILL' 1;" : ""}>confirmation_number</span>
            <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Data Tiket</span>
        </a>

        <!-- Data Morena: Laporan Tiket Morena -->
        <a
            class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "data-morena" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
            href="/admin/data-morena"
        >
            <span class="material-symbols-outlined shrink-0" style={activePage === "data-morena" ? "font-variation-settings: 'FILL' 1;" : ""}>database</span>
            <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Data Morena</span>
        </a>

        <!-- Data Ganti ODP: semua role -->
        <a
            class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "data-ganti-odp" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
            href="/admin/data-ganti-odp"
        >
            <span class="material-symbols-outlined shrink-0" style={activePage === "data-ganti-odp" ? "font-variation-settings: 'FILL' 1;" : ""}>swap_horiz</span>
            <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Data Ganti ODP</span>
        </a>

        <!-- INSERA SC: hanya ADMIN, KORLAP, HSA -->
        { canViewInsera && (
            <>
                <div class="sidebar-text pt-4 pb-1 px-3 mt-1">
                    <div class="flex items-center gap-2">
                        <div class="h-px flex-1 bg-border-color/50"></div>
                        <span class="text-[9px] font-black uppercase tracking-[0.2em] text-primary/40 whitespace-nowrap">INSERA SC</span>
                        <div class="h-px flex-1 bg-border-color/50"></div>
                    </div>
                </div>
                <a
                    class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "insera-data" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
                    href="/admin/insera-data"
                >
                    <span class="material-symbols-outlined shrink-0" style={activePage === "insera-data" ? "font-variation-settings: 'FILL' 1;" : ""}>downloading</span>
                    <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Ambil Data INSERA</span>
                </a>
                <a
                    class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "insera-tickets" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
                    href="/admin/insera-tickets"
                >
                    <span class="material-symbols-outlined shrink-0" style={activePage === "insera-tickets" ? "font-variation-settings: 'FILL' 1;" : ""}>assignment</span>
                    <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Data Tiket INSERA</span>
                </a>
                <a
                    class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "insera-view" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
                    href="/admin/insera-view"
                >
                    <span class="material-symbols-outlined shrink-0" style={activePage === "insera-view" ? "font-variation-settings: 'FILL' 1;" : ""}>view_list</span>
                    <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">INSERA View</span>
                </a>
                <a
                    class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "history-assign" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
                    href="/admin/history-assign"
                >
                    <span class="material-symbols-outlined shrink-0" style={activePage === "history-assign" ? "font-variation-settings: 'FILL' 1;" : ""}>history</span>
                    <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">History Assign</span>
                </a>
            </>
        )}

        <!-- Data Karyawan: ADMIN, KORLAP, HSA -->
        { canViewTechnicians && (
            <a
                class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "technicians" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
                href="/admin/technicians"
            >
                <span class="material-symbols-outlined shrink-0" style={activePage === "technicians" ? "font-variation-settings: 'FILL' 1;" : ""}>engineering</span>
                <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Data Karyawan</span>
            </a>
        )}

        <!-- System Control: ADMIN, KORLAP, HSA -->
        { canViewAnnouncement && (
            <>
                <div class="sidebar-text pt-4 pb-1 px-3 mt-1">
                    <div class="flex items-center gap-2">
                        <div class="h-px flex-1 bg-border-color/50"></div>
                        <span class="text-[9px] font-black uppercase tracking-[0.2em] text-primary/40 whitespace-nowrap">SYSTEM CONTROL</span>
                        <div class="h-px flex-1 bg-border-color/50"></div>
                    </div>
                </div>
                <a
                    class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "announcements" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
                    href="/admin/announcement"
                >
                    <span class="material-symbols-outlined shrink-0" style={activePage === "announcements" ? "font-variation-settings: 'FILL' 1;" : ""}>campaign</span>
                    <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Announcement</span>
                </a>
                <a
                    class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "configs" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
                    href="/admin/configs"
                >
                    <span class="material-symbols-outlined shrink-0" style={activePage === "configs" ? "font-variation-settings: 'FILL' 1;" : ""}>settings_suggest</span>
                    <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Configuration</span>
                </a>
            </>
        )}

        <a
            class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "technician-tickets" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
            href="/admin/technician-tickets"
        >
            <span class="material-symbols-outlined shrink-0" style={activePage === "technician-tickets" ? "font-variation-settings: 'FILL' 1;" : ""}>engineering</span>
            <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Ticket Teknisi</span>
        </a>

        <a
            class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 group ${activePage === "changelog" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-on-surface-variant hover:bg-surface-container-high hover:text-primary"}`}
            href="/admin/changelog"
        >
            <span class="material-symbols-outlined shrink-0" style={activePage === "changelog" ? "font-variation-settings: 'FILL' 1;" : ""}>history_edu</span>
            <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Update Log</span>
        </a>

        <div class="pt-4 mt-auto border-t border-border-color/50 space-y-2">
            <a class="flex items-center gap-3 px-4 py-3 rounded-xl text-on-surface-variant hover:text-primary hover:bg-surface-container-high transition-all duration-300" href="/">
                <span class="material-symbols-outlined shrink-0">public</span>
                <span class="sidebar-text font-headline tracking-tight font-bold whitespace-nowrap">Public View</span>
            </a>
        </div>
    </nav>

    <!-- Profile Footer -->
    <div class="mt-auto px-6 py-6 overflow-hidden">
        <div class="profile-card p-4 bg-surface-container rounded-2xl border border-border-color shadow-sm w-full transition-all duration-300 flex flex-col items-center">
            <div class="flex items-center gap-3 mb-4 w-full">
                <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-black text-xs shrink-0 border border-primary/20">
                    {username.substring(0, 2).toUpperCase()}
                </div>
                <div class="sidebar-text overflow-hidden transition-all duration-300 flex-1">
                    <p class="text-xs font-bold truncate leading-tight">{username}</p>
                    <p class="text-[9px] text-on-surface-variant uppercase font-black tracking-widest">{role}</p>
                </div>
            </div>
            <a href="/api/logout" class="logout-btn w-full py-2.5 bg-primary text-white text-[10px] font-bold rounded-xl hover:opacity-90 transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm shrink-0">logout</span>
                <span class="sidebar-text whitespace-nowrap uppercase tracking-widest">Logout</span>
            </a>
        </div>
    </div>
</aside>

<style is:global>
    :root {
        --sidebar-width: 256px;
        --sidebar-transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .sidebar-collapsed {
        --sidebar-width: 80px;
    }

    /* Shifting Main Content */
    main {
        margin-left: var(--sidebar-width) !important;
        transition: margin-left var(--sidebar-transition) !important;
    }

    /* Hide text globally in collapsed state */
    .sidebar-collapsed .sidebar-text {
        display: none !important;
    }
</style>

<style>
    /* Material Symbols Fix */
    .material-symbols-outlined {
        font-family: 'Material Symbols Outlined' !important;
        font-weight: normal;
        font-style: normal;
        font-size: 24px;
        line-height: 1;
        letter-spacing: normal;
        text-transform: none;
        display: inline-block;
        white-space: nowrap;
        word-wrap: normal;
        direction: ltr;
        -webkit-font-smoothing: antialiased;
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    /* Collapsed State Styles */
    :global(.sidebar-collapsed) #sidebar {
        width: 80px;
    }

    :global(.sidebar-collapsed) .sidebar-text {
        display: none;
    }

    :global(.sidebar-collapsed) nav a {
        justify-content: center;
        padding-left: 0;
        padding-right: 0;
        width: 48px;
        height: 48px;
        margin: 0 auto;
    }

    :global(.sidebar-collapsed) .profile-card {
        padding: 0.75rem 0.5rem;
        border: none;
        background: transparent;
        box-shadow: none;
    }

    :global(.sidebar-collapsed) .logout-btn {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        justify-content: center;
        padding: 0;
    }

    :global(.sidebar-collapsed) #toggleIcon {
        transform: rotate(180deg);
    }

    /* Custom Scrollbar */
    .custom-scrollbar::-webkit-scrollbar {
        width: 3px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(var(--primary-rgb, 0, 64, 161), 0.1);
        border-radius: 10px;
    }

    /* Animations */
    aside {
        width: 256px;
        transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>

<script is:inline>
    function initSidebar() {
        const toggle = document.getElementById("sidebarToggle");
        if (localStorage.getItem("sidebar-collapsed") === "true") {
            document.documentElement.classList.add("sidebar-collapsed");
        }
        
        toggle?.addEventListener("click", () => {
            const isCollapsed = document.documentElement.classList.toggle("sidebar-collapsed");
            localStorage.setItem("sidebar-collapsed", isCollapsed);
        });
    }
    initSidebar();
    document.addEventListener("astro:after-swap", initSidebar);
</script>
